// ============================================
// HTML ESCAPE
// ============================================
function escapeHtml(text) {
  return String(text || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

// ============================================
// CHUNKED CACHE
// ============================================
function putChunkedCache(key, data, expiry) {
  var cache = CacheService.getScriptCache();
  var json = JSON.stringify(data);
  if (json.length < CONFIG.MAX_CACHE_SIZE) {
    cache.put(key, json, expiry); cache.put(key + '_chunks', '0', expiry); return;
  }
  var chunks = [];
  for (var i = 0; i < json.length; i += CONFIG.MAX_CACHE_SIZE) chunks.push(json.substring(i, i + CONFIG.MAX_CACHE_SIZE));
  cache.put(key + '_chunks', String(chunks.length), expiry);
  for (var i = 0; i < chunks.length; i++) cache.put(key + '_' + i, chunks[i], expiry);
}

function getChunkedCache(key) {
  var cache = CacheService.getScriptCache();
  var n = cache.get(key + '_chunks');
  if (!n) { var d = cache.get(key); return d ? JSON.parse(d) : null; }
  var count = parseInt(n, 10);
  if (count === 0) { var d = cache.get(key); return d ? JSON.parse(d) : null; }
  var full = '';
  for (var i = 0; i < count; i++) { var c = cache.get(key + '_' + i); if (!c) return null; full += c; }
  return JSON.parse(full);
}

// ============================================
// JOB PERSISTENCE — HYBRID CACHE + DRIVE
// ============================================
var _jobsFolderId = null;

function _getJobsFolderId() {
  if (_jobsFolderId) return _jobsFolderId;
  var props = PropertiesService.getScriptProperties();
  var stored = props.getProperty('JOBS_FOLDER_ID');
  if (stored) {
    try { DriveApp.getFolderById(stored); _jobsFolderId = stored; return stored; } catch (e) { }
  }
  var parent = DriveApp.getFolderById(CONFIG.DRIVE_FOLDER_ID);
  var subs = parent.getFoldersByName('_job_states');
  var folder = subs.hasNext() ? subs.next() : parent.createFolder('_job_states');
  _jobsFolderId = folder.getId();
  props.setProperty('JOBS_FOLDER_ID', _jobsFolderId);
  return _jobsFolderId;
}

/**
 * v9.1: saveJobState now strips `htmlParts` before serialisation.
 * Content lives in per-page Drive backup files; job state carries only progress metadata.
 * This keeps the cache small (fixing the silent resume failures) and the Drive job file fast to write.
 */
function saveJobState(jobId, job, toDrive) {
  var slim = {};
  for (var k in job) {
    if (job.hasOwnProperty(k) && k !== 'htmlParts') slim[k] = job[k];
  }
  try { putChunkedCache('job_' + jobId, slim, CONFIG.CACHE_EXPIRY); } catch (e) { }
  if (toDrive) {
    try {
      var folder = DriveApp.getFolderById(_getJobsFolderId());
      var fname = 'job_' + jobId + '.json';
      var json = JSON.stringify(slim);
      var files = folder.getFilesByName(fname);
      if (files.hasNext()) files.next().setContent(json);
      else folder.createFile(fname, json, 'application/json');
    } catch (e) { Logger.log('saveJobState Drive error: ' + e.toString()); }
  }
}

function loadJobState(jobId) {
  try {
    var cached = getChunkedCache('job_' + jobId);
    if (cached) return normalizeJobState(cached);
  } catch (e) { }
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var files = folder.getFilesByName('job_' + jobId + '.json');
    if (files.hasNext()) {
      var job = JSON.parse(files.next().getBlob().getDataAsString());
      job = normalizeJobState(job);
      try { putChunkedCache('job_' + jobId, job, CONFIG.CACHE_EXPIRY); } catch (e2) { }
      return job;
    }
  } catch (e) { Logger.log('loadJobState Drive error: ' + e.toString()); }
  return null;
}

function deleteJobState(jobId) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var files = folder.getFilesByName('job_' + jobId + '.json');
    while (files.hasNext()) files.next().setTrashed(true);
  } catch (e) { }
  try { var cache = CacheService.getScriptCache(); cache.remove('job_' + jobId); cache.remove('job_' + jobId + '_chunks'); } catch (e) { }
}


function normalizeTocStructure(toc) {
  if (!Array.isArray(toc)) return [];
  return toc.map(function(item) {
    if (!item) return { title: 'Untitled Section', subheaders: [] };
    if (typeof item === 'string') return { title: item, subheaders: [] };

    var title = (item.title || item.heading || item.name || 'Untitled Section').toString();
    var subs = item.subheaders;
    if (!Array.isArray(subs)) {
      if (Array.isArray(item.subTopics)) subs = item.subTopics;
      else if (Array.isArray(item.subtopic)) subs = item.subtopic;
      else if (Array.isArray(item.topics)) subs = item.topics;
      else subs = [];
    }

    subs = subs.filter(function(s) {
      return s !== null && s !== undefined && String(s).trim() !== '';
    }).map(function(s) {
      return String(s);
    });

    return { title: title, subheaders: subs };
  });
}

function normalizeJobState(job) {
  if (!job || typeof job !== 'object') return job;

  // v9.1: htmlParts is no longer persisted, but legacy job files may contain it. Drop it.
  if (job.htmlParts) delete job.htmlParts;

  job.tocStructure = normalizeTocStructure(job.tocStructure);

  if (!job.allocation || typeof job.allocation !== 'object') {
    job.allocation = { pagesPerSubheader: CONFIG.MIN_PAGES_PER_SUBHEADER };
  }
  if (!job.allocation.pagesPerSubheader || isNaN(job.allocation.pagesPerSubheader)) {
    job.allocation.pagesPerSubheader = CONFIG.MIN_PAGES_PER_SUBHEADER;
  }

  if (!job.chunksPerSubheader || isNaN(job.chunksPerSubheader) || job.chunksPerSubheader < 1) {
    job.chunksPerSubheader = Math.max(1, Math.round(job.allocation.pagesPerSubheader || CONFIG.MIN_PAGES_PER_SUBHEADER));
  }

  if (!Array.isArray(job.chunkPlan) && job.allocation && Array.isArray(job.allocation.chunkPlan)) {
    job.chunkPlan = job.allocation.chunkPlan;
  }
  if (Array.isArray(job.chunkPlan)) {
    job.chunkPlan = job.chunkPlan.map(function(n) { return Math.max(1, parseInt(n, 10) || 1); });
  }
  if (!job.contentWordsPerGeneratedPage || isNaN(job.contentWordsPerGeneratedPage)) {
    job.contentWordsPerGeneratedPage = job.imagesEnabled === false ? CONFIG.WORDS_PER_PAGE : (CONFIG.WORDS_PER_PAGE_WITH_IMAGES || 180);
  }

  if (!job.costs || typeof job.costs !== 'object') {
    job.costs = {
      textInputTokens: 0,
      textOutputTokens: 0,
      imagesGenerated: 0,
      textCost: 0,
      imageCost: 0,
      totalCost: 0
    };
  }

  job.currentTask = parseInt(job.currentTask, 10) || 0;
  job.totalTasks = parseInt(job.totalTasks, 10) || 1;
  job.imagesEnabled = job.imagesEnabled !== false;

  if (!job.status) job.status = 'initialized';
  if (!job.courseName) job.courseName = 'Coursebook';

  return job;
}

// ============================================
// HTML CHUNK BACKUP — GOOGLE DRIVE (persistent per-page storage)
// Each backed-up chunk contains base64-embedded images — URLs never expire.
// ============================================
function backupChunkHtml(jobId, taskNum, htmlChunk) {
  if (!htmlChunk || htmlChunk.length === 0) return;
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var fname = 'html_' + jobId + '_' + String(taskNum).padStart(4, '0') + '.txt';
    var existing = folder.getFilesByName(fname);
    if (existing.hasNext()) existing.next().setContent(htmlChunk);
    else folder.createFile(fname, htmlChunk, 'text/plain');
  } catch (e) { Logger.log('backupChunkHtml error: ' + e.toString()); }
}

function getHtmlBackupInfo(jobId) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var prefix = 'html_' + jobId + '_';
    var files = folder.getFiles();
    var taskNums = [];
    while (files.hasNext()) {
      var f = files.next(), n = f.getName();
      if (n.indexOf(prefix) === 0 && n.indexOf('.txt') !== -1) {
        taskNums.push(parseInt(n.replace(prefix, '').replace('.txt', ''), 10));
      }
    }
    taskNums.sort(function(a, b) { return a - b; });
    return { found: taskNums.length > 0, chunkCount: taskNums.length, taskNums: taskNums };
  } catch (e) { return { found: false }; }
}

function loadBackupHtmlChunk(jobId, taskNum) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var fname = 'html_' + jobId + '_' + String(taskNum).padStart(4, '0') + '.txt';
    var files = folder.getFilesByName(fname);
    if (files.hasNext()) return { success: true, html: files.next().getBlob().getDataAsString() };
    return { success: false };
  } catch (e) { return { success: false }; }
}

function cleanupHtmlBackups(jobId) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var files = folder.getFiles();
    while (files.hasNext()) {
      var f = files.next(), n = f.getName();
      if (n.indexOf('html_' + jobId + '_') === 0 || n === 'htmlheader_' + jobId + '.txt') f.setTrashed(true);
    }
  } catch (e) { }
}


