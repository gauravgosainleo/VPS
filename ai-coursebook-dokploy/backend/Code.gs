// ============================================
// OPENAI API
// ============================================
function callOpenAI(prompt, maxTokens, systemPrompt) {
  var url = 'https://api.openai.com/v1/chat/completions';
  var apiKey = PropertiesService.getScriptProperties().getProperty('OPENAI_API_KEY');
  if (!apiKey) throw new Error('OPENAI_API_KEY is missing in Script Properties.');

  var sys = systemPrompt || 'You are an expert educational content writer creating professional coursebook content.';
  var modelName = (CONFIG.TEXT_MODEL || '').toLowerCase();
  var isReasoningModel = modelName.indexOf('gpt-5') === 0 || modelName.indexOf('o1') === 0 || modelName.indexOf('o3') === 0 || modelName.indexOf('o4') === 0;

  var requestedTokens = parseInt(maxTokens, 10) || 4000;

  var payload = {
    model: CONFIG.TEXT_MODEL,
    // For GPT-5/o-series, developer messages are recommended instead of the older system role.
    messages: [{ role: 'developer', content: sys }, { role: 'user', content: prompt }]
  };

  if (isReasoningModel) {
    // GPT-5 nano is a reasoning-capable Chat Completions model.
    // max_tokens can cause HTTP 400 with these models, so use max_completion_tokens.
    // Give small calls extra room because this limit includes invisible reasoning tokens too.
    payload.max_completion_tokens = Math.max(requestedTokens, 800);
    payload.reasoning_effort = 'minimal';
    // Do not send temperature for GPT-5/o-series; some reasoning models reject custom temperature values.
  } else {
    payload.max_tokens = requestedTokens;
    payload.temperature = 0.7;
  }

  var lastError = '';
  for (var a = 1; a <= CONFIG.MAX_RETRIES; a++) {
    try {
      var options = {
        method: 'post',
        contentType: 'application/json',
        headers: { 'Authorization': 'Bearer ' + apiKey },
        payload: JSON.stringify(payload),
        muteHttpExceptions: true
      };

      var r = UrlFetchApp.fetch(url, options);
      var code = r.getResponseCode();
      var responseText = r.getContentText();

      if (code === 200) {
        var j = JSON.parse(responseText);
        var msg = j.choices && j.choices[0] && j.choices[0].message ? j.choices[0].message : {};
        var content = msg.content || '';

        // Some newer responses may return content parts. Keep this compatible with plain strings.
        if (Array.isArray(content)) {
          content = content.map(function(part) {
            return part && (part.text || part.content || '') || '';
          }).join('');
        }

        if (!content && msg.refusal) throw new Error('OpenAI refusal: ' + msg.refusal);
        if (!content) throw new Error('OpenAI returned an empty response. Finish reason: ' + ((j.choices && j.choices[0] && j.choices[0].finish_reason) || 'unknown'));

        var usage = j.usage || {};
        return {
          content: content,
          usage: {
            inputTokens: usage.prompt_tokens || usage.input_tokens || 0,
            outputTokens: usage.completion_tokens || usage.output_tokens || 0
          }
        };
      }

      lastError = 'HTTP ' + code + ': ' + _extractOpenAIErrorMessage(responseText);
      if (code === 401) throw new Error('Invalid API key. ' + lastError);
      if (code === 404) throw new Error('Model not found or not available: ' + CONFIG.TEXT_MODEL + '. ' + lastError);
      if (code === 400) throw new Error(lastError);
      if (code === 429 && a < CONFIG.MAX_RETRIES) { Utilities.sleep(3000 * a); continue; }
      if (code >= 500 && a < CONFIG.MAX_RETRIES) { Utilities.sleep(3000 * a); continue; }
      if (a < CONFIG.MAX_RETRIES) Utilities.sleep(1000 * a);
    } catch (e) {
      lastError = e.toString();
      if (e.message && (
          e.message.indexOf('Invalid API key') !== -1 ||
          e.message.indexOf('Model not found') !== -1 ||
          e.message.indexOf('HTTP 400') !== -1 ||
          e.message.indexOf('OpenAI refusal') !== -1)) throw e;
      if (a < CONFIG.MAX_RETRIES) Utilities.sleep(1000 * a);
    }
  }
  throw new Error('OpenAI API failed after retries. Last: ' + lastError);
}


// ============================================
// HEADER-AWARE MULTI-TYPE VISUAL ENGINE
// ============================================
function chooseVisualType(seedText, purpose, chunkIndex) {
  var types = ['photorealistic image', 'process diagram', 'infographic', 'conceptual illustration', 'comparison diagram', 'workflow chart'];
  if (purpose === 'overview') types = ['infographic', 'conceptual illustration', 'photorealistic image', 'process diagram'];
  if (purpose === 'side') types = ['conceptual illustration', 'photorealistic image', 'comparison diagram', 'workflow chart'];

  var seed = String(seedText || '') + '|' + String(purpose || '') + '|' + String(chunkIndex || 0);
  var hash = 0;
  for (var i = 0; i < seed.length; i++) hash = ((hash << 5) - hash) + seed.charCodeAt(i);
  hash = Math.abs(hash);
  return types[hash % types.length];
}

function analyzeContentForImageWords(heading, sectionContext, visualTypeHint, nearbyHeaders) {
  var visualType = visualTypeHint || chooseVisualType(heading + ' ' + sectionContext, 'content', 0);
  var headerContext = Array.isArray(nearbyHeaders) && nearbyHeaders.length
    ? nearbyHeaders.filter(function(h) { return h && String(h).trim(); }).slice(0, 8).join(' | ')
    : '';

  var prompt = 'You are a visual planning expert for professional educational coursebooks.\n\n'
    + 'TASK: Create a highly relevant visual plan for one page. The visual must match the current header and surrounding headers, and it must vary the visual type across the document.\n\n'
    + 'CURRENT HEADER: "' + heading + '"\n'
    + 'PARENT / SECTION CONTEXT: "' + sectionContext + '"\n'
    + 'NEARBY HEADERS IN DOCUMENT: "' + headerContext + '"\n'
    + 'REQUESTED VISUAL TYPE: "' + visualType + '"\n\n'
    + 'RULES:\n'
    + '- Use the current header as the main relevance anchor.\n'
    + '- Use parent and nearby headers to avoid generic images.\n'
    + '- Prefer concrete objects, process steps, relationships, tools, workflows, environments, and domain-specific scenes.\n'
    + '- For diagrams/infographics, keep labels minimal and simple because image models can make small text imperfect.\n'
    + '- Do not repeat the same visual idea if another visual type would explain the header better.\n\n'
    + 'RESPOND IN EXACTLY THIS FORMAT:\n'
    + 'ANALYSIS: [one sentence]\n'
    + 'VISUAL_TYPE: [photorealistic image OR process diagram OR infographic OR conceptual illustration OR comparison diagram OR workflow chart]\n'
    + 'VISUAL_CONCEPTS: [5-8 concrete words/phrases, comma separated]\n'
    + 'WORD1: [first concrete keyword]\n'
    + 'WORD2: [second concrete keyword]\n'
    + 'IMAGE_DESCRIPTION: [one sentence describing the final visual]';

  try {
    var result = callOpenAI(prompt, 260, 'You create precise visual plans for coursebook pages. Be concrete, header-aware, and vary visual types.');
    var lines = result.content.trim().split('\n');
    var word1 = '', word2 = '', imageDesc = '', returnedType = visualType;
    for (var i = 0; i < lines.length; i++) {
      var line = lines[i].trim();
      if (line.toUpperCase().indexOf('WORD1') === 0) word1 = line.replace(/^WORD1\s*:\s*/i, '').trim().toLowerCase().replace(/['"]/g, '');
      else if (line.toUpperCase().indexOf('WORD2') === 0) word2 = line.replace(/^WORD2\s*:\s*/i, '').trim().toLowerCase().replace(/['"]/g, '');
      else if (line.toUpperCase().indexOf('VISUAL_TYPE') === 0) returnedType = line.replace(/^VISUAL_TYPE\s*:\s*/i, '').trim().toLowerCase().replace(/['"]/g, '') || visualType;
      else if (line.toUpperCase().indexOf('IMAGE_DESCRIPTION') === 0) imageDesc = line.replace(/^IMAGE_DESCRIPTION\s*:\s*/i, '').trim();
    }
    if (!word1 || !word2) { var fb = quickExtractWords(heading + ' ' + sectionContext); word1 = word1 || fb.word1; word2 = word2 || fb.word2; }
    return { word1: word1, word2: word2, imageDescription: imageDesc, visualType: returnedType, usage: result.usage };
  } catch (e) {
    var fb = quickExtractWords(heading + ' ' + sectionContext);
    return { word1: fb.word1, word2: fb.word2, imageDescription: '', visualType: visualType, usage: { inputTokens: 0, outputTokens: 0 } };
  }
}

function quickExtractWords(heading) {
  var stopWords = ['the','a','an','and','or','but','in','on','at','to','for','of','with','by','from','is','are','was','were','be','been','being','have','has','had','do','does','did','will','would','could','should','may','might','shall','can','this','that','these','those','it','its','how','what','why','when','where','which','who','whom','introduction','overview','understanding','chapter','section','part','unit','module','day','lesson'];
  var words = String(heading || '').replace(/[^a-zA-Z\s]/g, '').toLowerCase().split(/\s+/).filter(function(w) { return w.length > 2 && stopWords.indexOf(w) === -1; });
  words.sort(function(a, b) { return b.length - a.length; });
  return { word1: words[0] || 'professional', word2: words[1] || 'workspace' };
}

function buildImagePromptFromAnalysis(word1, word2, imageDescription, visualType, heading, sectionContext, nearbyHeaders) {
  var type = (visualType || 'photorealistic image').toLowerCase();
  var headerContext = Array.isArray(nearbyHeaders) && nearbyHeaders.length ? nearbyHeaders.slice(0, 6).join(' | ') : '';
  var base = 'Create a professional coursebook visual. Current page header: "' + heading + '". Parent section/context: "' + sectionContext + '".';
  if (headerContext) base += ' Nearby headers for relevance: ' + headerContext + '.';
  base += ' Core visual keywords: "' + word1 + '" and "' + word2 + '".';
  if (imageDescription && imageDescription.length > 10) base += ' Scene/structure: ' + imageDescription + '.';

  if (type.indexOf('infographic') !== -1) {
    return base
      + ' Render as a clean modern infographic with 3-5 simple visual blocks, clear hierarchy, minimal short labels only, icons/shapes where useful, balanced whitespace, and a polished corporate training style. Avoid tiny paragraphs, clutter, watermarks, logos, or unreadable text.';
  }
  if (type.indexOf('diagram') !== -1 || type.indexOf('workflow') !== -1 || type.indexOf('chart') !== -1) {
    return base
      + ' Render as a clean educational ' + type + ' using simple nodes, arrows, stages, and relationships. Use only a few short labels if needed. Make the structure easy to understand at a glance. Avoid dense text, watermarks, logos, UI screenshots, or decorative clutter.';
  }
  if (type.indexOf('illustration') !== -1) {
    return base
      + ' Render as a polished conceptual illustration with tangible objects and a clear metaphor tied to the header. Modern professional training style, clean composition, balanced whitespace, no text, no labels, no watermarks.';
  }
  return base
    + ' Render as a high-quality photorealistic image with a single focused subject, realistic professional environment, natural lighting, sharp detail, uncluttered background, no text, no labels, no watermarks.';
}

function _extractOpenAIErrorMessage(responseText) {
  try {
    var parsed = JSON.parse(responseText || '{}');
    if (parsed.error) {
      if (parsed.error.message) return parsed.error.message;
      return JSON.stringify(parsed.error).substring(0, 800);
    }
  } catch (e) { }
  return String(responseText || '').substring(0, 800);
}

function _throttleImageRequests() {
  var delayMs = parseInt(CONFIG.IMAGE_REQUEST_DELAY_MS, 10) || 0;
  if (!delayMs) return;
  try {
    var lock = LockService.getScriptLock();
    lock.waitLock(30000);
    var props = PropertiesService.getScriptProperties();
    var now = Date.now();
    var last = parseInt(props.getProperty('LAST_IMAGE_REQUEST_MS') || '0', 10) || 0;
    var wait = delayMs - (now - last);
    if (wait > 0) Utilities.sleep(wait);
    props.setProperty('LAST_IMAGE_REQUEST_MS', String(Date.now()));
    lock.releaseLock();
  } catch (e) {
    // Throttling is best-effort only. Continue rather than blocking generation.
  }
}

/**
 * GPT Image 2 returns base64 image data from the Image API. We embed it directly so Drive backups
 * and downloaded HTML/PDF never depend on expiring image URLs.
 *
 * Important: do NOT silently hide failures. If the image API fails, throw an error so the UI pauses
 * and shows the real cause instead of producing a text-only coursebook.
 */
function generateImageWithRetry(prompt, size, deadlineMs) {
  var url = 'https://api.openai.com/v1/images/generations';
  var apiKey = PropertiesService.getScriptProperties().getProperty('OPENAI_API_KEY');
  if (!apiKey) throw new Error('OPENAI_API_KEY is missing in Script Properties.');

  // Keep the GPT Image 2 payload intentionally simple and aligned with the current Image API examples.
  // The API defaults to one image and returns data[0].b64_json.
  var payload = {
    model: CONFIG.IMAGE_MODEL,
    prompt: prompt,
    size: size || '1024x1024',
    quality: CONFIG.IMAGE_QUALITY || 'medium',
    output_format: CONFIG.IMAGE_OUTPUT_FORMAT || 'png'
  };

  var options = {
    method: 'post',
    contentType: 'application/json',
    headers: { 'Authorization': 'Bearer ' + apiKey },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };

  var lastError = '';
  for (var a = 1; a <= CONFIG.MAX_RETRIES; a++) {
    if (deadlineMs && Date.now() > deadlineMs) {
      lastError = 'Image generation skipped because the Apps Script chunk deadline was reached.';
      break;
    }

    try {
      _throttleImageRequests();
      var r = UrlFetchApp.fetch(url, options);
      var code = r.getResponseCode();
      var txt = r.getContentText();

      if (code === 200) {
        var j = JSON.parse(txt);
        if (j.data && j.data[0] && j.data[0].b64_json) {
          var fmt = CONFIG.IMAGE_OUTPUT_FORMAT || 'png';
          return 'data:image/' + fmt + ';base64,' + j.data[0].b64_json;
        }
        lastError = 'Image API returned 200 but no data[0].b64_json. Response: ' + txt.substring(0, 500);
      } else {
        lastError = 'Image API HTTP ' + code + ': ' + _extractOpenAIErrorMessage(txt);
      }

      if (code === 401) throw new Error('Invalid OpenAI API key for image generation. ' + lastError);
      if (code === 403) throw new Error('OpenAI image generation is not enabled for this project/org. ' + lastError);
      if (code === 404) throw new Error('Image model not found or not available: ' + CONFIG.IMAGE_MODEL + '. ' + lastError);
      if (code === 400) throw new Error(lastError);

      if ((code === 429 || code >= 500) && a < CONFIG.MAX_RETRIES) {
        Utilities.sleep(Math.min(60000, 15000 * a));
        continue;
      }

      if (a < CONFIG.MAX_RETRIES) Utilities.sleep(2000 * a);
    } catch (e) {
      lastError = e.toString();
      if (e.message && (
          e.message.indexOf('Invalid OpenAI API key') !== -1 ||
          e.message.indexOf('not available') !== -1 ||
          e.message.indexOf('not enabled') !== -1 ||
          e.message.indexOf('Image API HTTP 400') !== -1)) throw e;
      if (a < CONFIG.MAX_RETRIES) Utilities.sleep(2000 * a);
    }
  }

  Logger.log('Image generation failed after retries. Last: ' + lastError);
  if (CONFIG.STRICT_IMAGE_FAILURES !== false) throw new Error('Image generation failed: ' + lastError);
  return generateColorPlaceholder('image failed');
}

function generateColorPlaceholder(topic) {
  var colors = ['#3182ce','#38a169','#805ad5','#d69e2e','#e53e3e'];
  var color = colors[Math.floor(Math.random() * colors.length)];
  var enc = encodeURIComponent((topic || '').substring(0, 30));
  return 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300"><rect fill="' + color + '" width="400" height="300"/><text fill="white" font-family="Arial" font-size="16" x="200" y="150" text-anchor="middle">' + enc + '</text></svg>';
}

// Helper — "was this a real generated image?" (excludes only SVG placeholders, includes base64 PNG/JPEG/WebP)
function isRealGeneratedImage(urlOrData) {
  if (!urlOrData) return false;
  return urlOrData.indexOf('data:image/svg') !== 0;
}

function generateSectionImage(sectionTitle, context, deadlineMs, visualTypeHint, nearbyHeaders) {
  if (CONFIG.USE_PLACEHOLDER_IMAGES) return { url: generateColorPlaceholder(sectionTitle), analysisUsage: { inputTokens: 0, outputTokens: 0 }, visualType: 'placeholder' };
  var visualType = visualTypeHint || chooseVisualType(sectionTitle + ' ' + context, 'overview', 0);
  var analysis = analyzeContentForImageWords(sectionTitle, context, visualType, nearbyHeaders);
  var prompt = buildImagePromptFromAnalysis(analysis.word1, analysis.word2, analysis.imageDescription, analysis.visualType || visualType, sectionTitle, context, nearbyHeaders);
  var imageUrl = generateImageWithRetry(prompt, '1024x1024', deadlineMs);
  return { url: imageUrl, analysisUsage: analysis.usage, visualType: analysis.visualType || visualType };
}

function generateSmallContextImage(topic, context, deadlineMs, visualTypeHint, nearbyHeaders) {
  var visualType = visualTypeHint || chooseVisualType(topic + ' ' + context, 'side', 0);
  var analysis = analyzeContentForImageWords(topic, context, visualType, nearbyHeaders);
  var prompt = buildImagePromptFromAnalysis(analysis.word1, analysis.word2, analysis.imageDescription, analysis.visualType || visualType, topic, context, nearbyHeaders);
  var imageUrl = generateImageWithRetry(prompt, '1024x1024', deadlineMs);
  return { url: imageUrl, analysisUsage: analysis.usage, visualType: analysis.visualType || visualType };
}

// ============================================
// AI SINGLE IMAGE (for editor)
// ============================================
function generateSingleImage(prompt) {
  try {
    if (!prompt || !prompt.trim()) return { success: false, message: 'No prompt' };
    var lower = prompt.toLowerCase();
    var wantsStructured = lower.indexOf('diagram') !== -1 || lower.indexOf('infographic') !== -1 || lower.indexOf('flowchart') !== -1 || lower.indexOf('workflow') !== -1 || lower.indexOf('chart') !== -1;
    var finalPrompt = 'Professional high-quality coursebook visual: ' + prompt
      + '. Clean composition, well-lit, polished training material style.'
      + (wantsStructured ? ' Use a simple structured layout with minimal short labels only; avoid dense text and clutter.' : ' No text, no words, no labels, no watermarks.');
    var imageUrl = generateImageWithRetry(finalPrompt, '1024x1024');
    if (imageUrl && isRealGeneratedImage(imageUrl)) return { success: true, imageUrl: imageUrl };
    return { success: false, message: 'Failed to generate' };
  } catch (e) { return { success: false, message: e.toString() }; }
}

// ============================================
// TOC GENERATION & PARSING
// ============================================
function generateTOCFromTopic(topic, numDays) {
  var days = Math.max(1, Math.min(parseInt(numDays, 10) || 3, 30));
  var prompt = 'Create a detailed Table of Contents for a ' + days + '-day training coursebook on "' + topic + '".\n\n'
    + 'RULES:\n- Organize day-wise: Day 1, Day 2, etc.\n- Each day: 3-5 major sections\n- Each section: 2-4 subtopics indented with "   - "\n'
    + '- Day 1: fundamentals/introduction\n- Middle days: core concepts\n- Last day: advanced topics, best practices, recap\n- Logical progression basic→advanced\n\n'
    + 'FORMAT:\n1. Day 1: [Title]\n   - Subtopic A\n   - Subtopic B\n\n2. Day 1: [Next Title]\n   - Subtopic A\n\nReturn ONLY the TOC text.';
  var result = callOpenAI(prompt, 3000);
  return { success: true, toc: result.content.trim(), usage: result.usage };
}

function parseTOC(tocText) {
  var lines = String(tocText || '').split('\n').filter(function(l) { return l.trim(); });
  var structure = [], cur = null;
  for (var i = 0; i < lines.length; i++) {
    var line = lines[i], t = line.trim(); if (!t) continue;
    var isSub = line.startsWith('  ') || line.startsWith('\t') || t.startsWith('-') || t.startsWith('•') || /^[a-z]\)/.test(t) || /^[ivx]+\)/.test(t.toLowerCase());
    if (isSub && cur) cur.subheaders.push(t.replace(/^[-•]\s*/, '').replace(/^[a-z]\)\s*/i, '').replace(/^[ivx]+\)\s*/i, ''));
    else { cur = { title: t.replace(/^\d+[\.\)]\s*/, ''), subheaders: [] }; structure.push(cur); }
  }
  return structure;
}

function getTotalSubheaders(toc) { toc = normalizeTocStructure(toc); var t = 0; for (var i = 0; i < toc.length; i++) t += Math.max(1, (toc[i].subheaders || []).length); return t; }

