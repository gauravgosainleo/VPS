// ============================================
// DRIVE SAVE (PDF)
// ============================================
function _normalizeBase64Only_(base64Data) {
  var raw = String(base64Data || '');
  if (raw.indexOf(',') !== -1) raw = raw.split(',')[1];
  return raw;
}

function _safeCoursebookFilename_(courseName) {
  var ts = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd_HH-mm-ss');
  var base = String(courseName || 'AI_Coursebook').replace(/[^a-z0-9]/gi, '_');
  if (!base) base = 'AI_Coursebook';
  return base + '_Coursebook_' + ts + '.pdf';
}

function makePdfBlobFromBase64_(base64Data, courseNameOrFilename) {
  var raw = _normalizeBase64Only_(base64Data);
  var name = String(courseNameOrFilename || '');
  if (!/\.pdf$/i.test(name)) name = _safeCoursebookFilename_(name);
  return Utilities.newBlob(Utilities.base64Decode(raw), 'application/pdf', name);
}

function savePdfBlobToDrive_(pdfBlob, courseName) {
  var folderId = CONFIG.DRIVE_FOLDER_ID;
  if (!folderId) return { success: false, message: 'No folder' };
  var folder = DriveApp.getFolderById(folderId);
  if (!pdfBlob.getName || !pdfBlob.getName()) pdfBlob.setName(_safeCoursebookFilename_(courseName));
  var file = folder.createFile(pdfBlob);
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  return { success: true, fileUrl: file.getUrl(), fileId: file.getId(), filename: file.getName() };
}

function savePdfToDrive(base64Data, courseName) {
  try {
    var blob = makePdfBlobFromBase64_(base64Data, courseName);
    return savePdfBlobToDrive_(blob, courseName);
  } catch (e) { return { success: false, message: e.toString() }; }
}

// ============================================
// KOENIG RMS/GHL DB UPLOAD INTEGRATION
// ============================================
function _parseJsonResponse_(response) {
  var text = '';
  try { text = response.getContentText(); } catch (e) {}
  try { return { json: JSON.parse(text), raw: text }; }
  catch (e2) { return { json: null, raw: text }; }
}

function _parseMaybeJsonString_(value) {
  if (value === null || value === undefined) return null;
  if (Object.prototype.toString.call(value) === '[object Array]' || typeof value === 'object') return value;
  var text = String(value || '').trim();
  if (!text) return null;
  for (var i = 0; i < 3; i++) {
    try {
      var parsed = JSON.parse(text);
      if (typeof parsed === 'string') { text = parsed.trim(); continue; }
      return parsed;
    } catch (e) { break; }
  }
  try { return JSON.parse(text.replace(/^"|"$/g, '').replace(/\\"/g, '"')); }
  catch (e2) { return null; }
}

function _contentToRows_(content) {
  var parsed = _parseMaybeJsonString_(content);
  if (!parsed) return [];
  if (Object.prototype.toString.call(parsed) === '[object Array]') return parsed;
  if (typeof parsed === 'object') return [parsed];
  return [];
}

function _getFieldIgnoreCase_(obj, fieldName) {
  if (!obj || typeof obj !== 'object') return '';
  if (obj[fieldName] !== undefined && obj[fieldName] !== null) return obj[fieldName];
  var target = String(fieldName).toLowerCase();
  for (var k in obj) {
    if (obj.hasOwnProperty(k) && String(k).toLowerCase() === target) return obj[k];
  }
  return '';
}

function getEmployeeCodeApiToken_(forceRefresh) {
  var cfg = CONFIG.EMP_CODE_API || {};
  var cacheKey = 'coursebook_emp_code_api_token_v1';
  if (!forceRefresh) {
    try { var cached = CacheService.getScriptCache().get(cacheKey); if (cached) return JSON.parse(cached); } catch (e) {}
  }
  var url = String(cfg.BASE_URL || '').replace(/\/+$/, '') + '/api/Kites/Operator/GetToken';
  var response = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/json',
    headers: { 'Accept': 'application/json' },
    payload: JSON.stringify({ userName: cfg.USERNAME, userPassword: cfg.PASSWORD, userRole: cfg.ROLE }),
    muteHttpExceptions: true
  });
  var code = response.getResponseCode();
  var parsed = _parseJsonResponse_(response);
  if (code < 200 || code >= 300 || !parsed.json || parsed.json.statuscode !== 200 || !parsed.json.content) {
    throw new Error('Employee token API failed. HTTP ' + code + ': ' + (parsed.raw || '').substring(0, 300));
  }
  var content = parsed.json.content;
  if (!content.accessToken || !content.deviceToken) throw new Error('Employee token API did not return accessToken/deviceToken.');
  var tokenInfo = { accessToken: content.accessToken, deviceToken: content.deviceToken };
  try { CacheService.getScriptCache().put(cacheKey, JSON.stringify(tokenInfo), 1800); } catch (e2) {}
  return tokenInfo;
}

function fetchEmpCodeByEmail_(officialEmail) {
  var email = String(officialEmail || '').trim();
  if (!email) throw new Error('User email is required to fetch EmpCode.');
  var cfg = CONFIG.EMP_CODE_API || {};
  var token = getEmployeeCodeApiToken_(false);
  var base = String(cfg.BASE_URL || '').replace(/\/+$/, '');
  var url = base + '/api/Kites/Operator/common?apikey=' + encodeURIComponent(cfg.API_KEY) +
    '&accessToken=' + encodeURIComponent(token.accessToken) +
    '&deviceToken=' + encodeURIComponent(token.deviceToken);

  function callApi() {
    return UrlFetchApp.fetch(url, {
      method: 'post', contentType: 'application/json', headers: { 'Accept': 'application/json' },
      payload: JSON.stringify({ OfficialEmail: email }), muteHttpExceptions: true
    });
  }

  var response = callApi();
  var code = response.getResponseCode();
  var parsed = _parseJsonResponse_(response);
  if ((code === 401 || code === 403 || (parsed.json && parsed.json.statuscode && parsed.json.statuscode !== 200)) && (!parsed.json || !parsed.json.content)) {
    token = getEmployeeCodeApiToken_(true);
    url = base + '/api/Kites/Operator/common?apikey=' + encodeURIComponent(cfg.API_KEY) +
      '&accessToken=' + encodeURIComponent(token.accessToken) +
      '&deviceToken=' + encodeURIComponent(token.deviceToken);
    response = callApi();
    code = response.getResponseCode();
    parsed = _parseJsonResponse_(response);
  }
  if (code < 200 || code >= 300 || !parsed.json || parsed.json.statuscode !== 200) {
    throw new Error('Get EmpCode API failed for ' + email + '. HTTP ' + code + ': ' + (parsed.raw || '').substring(0, 300));
  }
  var rows = _contentToRows_(parsed.json.content);
  var emailLower = email.toLowerCase();
  var row = null;
  for (var i = 0; i < rows.length; i++) {
    var rowEmail = String(_getFieldIgnoreCase_(rows[i], 'OfficialEmail') || '').trim().toLowerCase();
    var rowEmpCode = _getFieldIgnoreCase_(rows[i], 'EmpCode');
    if (rowEmail === emailLower && rowEmpCode !== null && rowEmpCode !== undefined && String(rowEmpCode).trim() !== '') { row = rows[i]; break; }
  }
  if (!row) {
    for (var j = 0; j < rows.length; j++) {
      var empCodeCandidate = _getFieldIgnoreCase_(rows[j], 'EmpCode');
      if (empCodeCandidate !== null && empCodeCandidate !== undefined && String(empCodeCandidate).trim() !== '') { row = rows[j]; break; }
    }
  }
  if (!row) throw new Error('No EmpCode found for email: ' + email + '. API response content: ' + String(parsed.json.content || '').substring(0, 300));
  return {
    empCode: String(_getFieldIgnoreCase_(row, 'EmpCode') || '').trim(),
    employeeName: String(_getFieldIgnoreCase_(row, 'EmployeeName') || '').trim(),
    officialEmail: String(_getFieldIgnoreCase_(row, 'OfficialEmail') || email).trim()
  };
}

function fetchEmpCodeByEmail(officialEmail) {
  try { return fetchEmpCodeByEmail_(officialEmail); }
  catch (e) { return { success: false, message: e.toString() }; }
}

