// LOGGING
// ============================================
function logUserToSpreadsheet(userName, userEmail, courseName, jobId, configJson) {
  try {
    var ssId = CONFIG.USER_LOGS_SPREADSHEET_ID; if (!ssId) return { success: false };
    var ss = SpreadsheetApp.openById(ssId);
    var sheet = ss.getSheetByName(CONFIG.USER_LOGS_SHEET_NAME);
    var HEADER = ['Timestamp', 'Name', 'Email', 'Title', 'Drive Link', 'Download Link', 'Status', 'Cost', 'Job ID', 'Config'];
    if (!sheet) {
      sheet = ss.insertSheet(CONFIG.USER_LOGS_SHEET_NAME);
      sheet.getRange(1, 1, 1, HEADER.length).setValues([HEADER]).setFontWeight('bold');
    }
    // Always normalise header to full 10 columns (fixes legacy sheets where Resume button never showed)
    var headerRow = sheet.getRange(1, 1, 1, HEADER.length).getValues()[0];
    if (!headerRow[8] || headerRow[8] !== 'Job ID' || !headerRow[9] || headerRow[9] !== 'Config') {
      sheet.getRange(1, 1, 1, HEADER.length).setValues([HEADER]).setFontWeight('bold');
    }
    var r = sheet.appendRowWithIndex([
      new Date().toLocaleString(),
      userName || 'N/A',
      userEmail || 'N/A',
      courseName || 'N/A',
      'Pending',
      'Not Downloaded',
      'Generating',
      'Pending',
      jobId || '',
      configJson || ''
    ]);
    SpreadsheetApp.flush(); // force write before returning — so resume button shows immediately
    return { success: true, row: r };
  } catch (e) { Logger.log('logUserToSpreadsheet error: ' + e.toString()); return { success: false }; }
}

