function generateCoverPage(courseName) {
  var date = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  return '  <div class="page cover-page">\n    <h1>' + escapeHtml(courseName) + '</h1>\n'
    + '    <p class="subtitle">Comprehensive Training Coursebook</p>\n'
    + '    <p class="date">Generated on ' + date + '</p>\n  </div>\n';
}

function generateTableOfContentsPage(toc, pagesPerSubheader) {
  var html = '  <div class="page toc-page">\n    <h2>Table of Contents</h2>\n';
  var pageNum = 3;
  for (var i = 0; i < toc.length; i++) {
    html += '    <div class="toc-item main"><span>' + (i + 1) + '. ' + escapeHtml(toc[i].title) + '</span><span>' + pageNum + '</span></div>\n';
    pageNum++;
    for (var s = 0; s < toc[i].subheaders.length; s++) {
      html += '    <div class="toc-item sub"><span>' + escapeHtml(toc[i].subheaders[s]) + '</span><span>' + pageNum + '</span></div>\n';
      pageNum += pagesPerSubheader;
    }
    if (toc[i].subheaders.length === 0) pageNum += pagesPerSubheader;
  }
  html += '    <div class="toc-item main"><span>Course Recap</span><span>' + pageNum + '</span></div>\n';
  html += '  </div>\n';
  return html;
}

function generateOverviewPageHtml(sectionTitle, content, imageUrl, sectionNum) {
  var imgBlock = (imageUrl && isRealGeneratedImage(imageUrl))
    ? '    <div class="image-container centered"><img src="' + imageUrl + '" alt="' + escapeHtml(sectionTitle) + '"></div>\n'
    : '';
  return '  <div class="page overview-page">\n'
    + '    <div class="section-label">Section ' + sectionNum + '</div>\n'
    + '    <h2 class="section-title">' + escapeHtml(sectionTitle) + '</h2>\n'
    + imgBlock
    + '    <div class="overview-content">' + content + '</div>\n  </div>\n';
}

function generateSingleChunkHtml(subheader, content, mainImageUrl, sideImageUrl, imageSide, sectionNum, subheaderNum, chunkIndex, imagesEnabled) {
  var html = '\n  <div class="content-section clearfix">\n';
  if (chunkIndex === 0) {
    html += '    <div class="section-label">Section ' + sectionNum + '.' + subheaderNum + '</div>\n';
    html += '    <h2 class="subheader-title">' + escapeHtml(subheader) + '</h2>\n';
  } else {
    html += '    <div class="section-label">Section ' + sectionNum + '.' + subheaderNum + ' — ' + escapeHtml(subheader) + ' (continued)</div>\n';
    html += '    <div class="chunk-continuation"></div>\n';
  }
  if (imagesEnabled && mainImageUrl && isRealGeneratedImage(mainImageUrl)) {
    html += '    <div class="image-container centered"><img src="' + mainImageUrl + '" alt="' + escapeHtml(subheader) + '"></div>\n';
  }
  if (imagesEnabled && sideImageUrl && isRealGeneratedImage(sideImageUrl)) {
    html += '    <div class="image-container ' + imageSide + '"><img src="' + sideImageUrl + '" alt="' + escapeHtml(subheader) + ' illustration"></div>\n';
  }
  html += '    <div class="content">\n      ' + content + '\n    </div>\n';
  html += '    <div class="clearfix"></div>\n  </div>\n';
  return html;
}

function generateRecapPageHtml(content, courseName) {
  return '  <div class="page recap-page">\n    <h2>Course Recap: ' + escapeHtml(courseName) + '</h2>\n'
    + '    <div class="content">' + content + '</div>\n  </div>\n';
}

// ============================================
// CONTENT GENERATION
// ============================================
function generateSectionOverview(sectionTitle, subheaders) {
  var subList = subheaders.length > 0 ? subheaders.map(function(s, i) { return (i + 1) + '. ' + s; }).join('\n') : 'Various aspects of ' + sectionTitle;
  var prompt = 'Write a comprehensive section overview (300-400 words) for "' + sectionTitle + '".\n\nThis section covers:\n' + subList
    + '\n\nInclude:\n1. Introduction\n2. Why important\n3. What readers will learn\n4. How topics connect\n\nFormat in HTML with paragraphs. Professional, educational tone.';
  return callOpenAI(prompt, 1000);
}

function generateSubheaderContent(subheader, sectionTitle, courseName, chunkIndex, totalChunks, totalPages, wordsPerPage) {
  var effectiveWordsPerPage = parseInt(wordsPerPage, 10) || CONFIG.WORDS_PER_PAGE;
  var wordsPerChunk = Math.ceil((effectiveWordsPerPage * totalPages) / Math.max(1, totalChunks));
  var chunkFocus = '';
  if (totalChunks === 1) chunkFocus = 'Cover all aspects comprehensively';
  else if (chunkIndex === 0) chunkFocus = 'Focus on introduction, definitions, and foundational concepts';
  else if (chunkIndex === totalChunks - 1) chunkFocus = 'Focus on advanced topics, best practices, and conclusions';
  else chunkFocus = 'Focus on detailed explanations, examples, and practical applications';

  var prompt = 'Write educational content (' + wordsPerChunk + ' words) for "' + subheader + '" as part of "' + sectionTitle + '" in the course "' + courseName + '".\n\n'
    + 'This is chunk ' + (chunkIndex + 1) + ' of ' + totalChunks + '. ' + chunkFocus + '\n\n'
    + 'Requirements:\n- Professional, educational tone\n- Specific examples and explanations\n- Proper HTML formatting\n- Engaging and informative\n\n'
    + 'Use these HTML elements:\n'
    + '- <h3> for subsection titles\n'
    + '- <p> for paragraphs\n'
    + '- <strong> for emphasis\n'
    + '- <ul><li> or <ol><li> for lists\n'
    + '- <div class="callout"><div class="callout-title">💡 Title</div><p>Content</p></div> for important notes\n'
    + '- <div class="example"><h4>Example</h4><p>Content</p></div> for examples\n'
    + '- <blockquote> for quotes or key statements\n'
    + '- <table> for data comparisons when appropriate\n\n'
    + 'Write in a professional, educational tone. Be specific and detailed.';
  return callOpenAI(prompt, 4000);
}

function generateRecapContent(toc, courseName) {
  var topics = toc.map(function(t, i) { return (i + 1) + '. ' + t.title; }).join('\n');
  var prompt = 'Write a comprehensive course recap (800-1000 words) for "' + courseName + '" covering:\n' + topics
    + '\n\nInclude:\n1. Course Summary\n2. Key Takeaways (8-10 bullet points)\n3. Skills Acquired\n4. Next Steps\n5. Resources for Continued Learning\n6. Final Thoughts\n\nFormat in HTML with proper headings and structure.';
  return callOpenAI(prompt, 2500);
}

// ============================================
// ALLOCATION HELPERS
// ============================================
function _buildSubheaderChunkPlan_(totalContentPages, totalSubheaders) {
  totalSubheaders = Math.max(1, parseInt(totalSubheaders, 10) || 1);
  totalContentPages = Math.max(totalSubheaders, parseInt(totalContentPages, 10) || totalSubheaders);
  totalContentPages = Math.min(totalContentPages, totalSubheaders * CONFIG.MAX_PAGES_PER_SUBHEADER);

  var base = Math.floor(totalContentPages / totalSubheaders);
  var extra = totalContentPages % totalSubheaders;
  var plan = [];
  for (var i = 0; i < totalSubheaders; i++) {
    plan.push(Math.max(1, Math.min(CONFIG.MAX_PAGES_PER_SUBHEADER, base + (i < extra ? 1 : 0))));
  }
  return plan;
}

function calculatePageAllocation(totalPages, toc) {
  toc = normalizeTocStructure(toc);
  var totalSub = Math.max(1, getTotalSubheaders(toc));
  var requested = Math.max(1, Math.min(parseInt(totalPages, 10) || 100, CONFIG.MAX_TOTAL_PAGES));

  // The visible coursebook is built from page blocks: cover, TOC, section overview pages,
  // one or more content pages per subheader, and a recap page. Keep that block count as
  // close as possible to the user-selected page count instead of forcing 10+ pages/subtopic.
  var reserved = 2 + toc.length + 1;
  var minPossible = reserved + totalSub;
  var maxPossible = reserved + totalSub * CONFIG.MAX_PAGES_PER_SUBHEADER;
  var targetTotal = Math.max(minPossible, Math.min(requested, maxPossible));
  var targetContentPages = targetTotal - reserved;
  var chunkPlan = _buildSubheaderChunkPlan_(targetContentPages, totalSub);
  var actualContentPages = chunkPlan.reduce(function(sum, n) { return sum + n; }, 0);
  var avgPagesPerSubheader = actualContentPages / totalSub;

  return {
    pagesPerSubheader: avgPagesPerSubheader,
    totalSubheaders: totalSub,
    reserved: reserved,
    requested: requested,
    estimatedTotal: reserved + actualContentPages,
    targetTotal: targetTotal,
    chunkPlan: chunkPlan
  };
}

function _getGlobalSubheaderIndex_(sectionIndex, subheaderIndex, toc) {
  toc = normalizeTocStructure(toc);
  var idx = 0;
  for (var i = 0; i < sectionIndex; i++) idx += Math.max(1, (toc[i].subheaders || []).length);
  return idx + (parseInt(subheaderIndex, 10) || 0);
}

function getTaskInfo(taskNum, toc, chunksPerSubheader, chunkPlan) {
  toc = normalizeTocStructure(toc);
  chunksPerSubheader = Math.max(1, parseInt(chunksPerSubheader, 10) || 1);
  chunkPlan = Array.isArray(chunkPlan) ? chunkPlan : null;

  var t = 1;
  var globalSubIdx = 0;
  for (var si = 0; si < toc.length; si++) {
    if (t === taskNum) return { type: 'overview', sectionIndex: si };
    t++;
    var subs = Array.isArray(toc[si].subheaders) ? toc[si].subheaders : [];
    var sc = Math.max(1, subs.length);
    for (var sub = 0; sub < sc; sub++) {
      var chunksForThisSubheader = chunkPlan ? (parseInt(chunkPlan[globalSubIdx], 10) || 1) : chunksPerSubheader;
      chunksForThisSubheader = Math.max(1, chunksForThisSubheader);
      for (var ci = 0; ci < chunksForThisSubheader; ci++) {
        if (t === taskNum) return {
          type: 'content', sectionIndex: si, subheaderIndex: sub, chunkIndex: ci,
          totalChunksForSubheader: chunksForThisSubheader,
          globalSubheaderIndex: globalSubIdx
        };
        t++;
      }
      globalSubIdx++;
    }
  }
  return { type: 'recap' };
}

function getNearbyHeadersForVisual(toc, sectionIndex, subheaderIndex) {
  toc = normalizeTocStructure(toc);
  var headers = [];
  if (toc[sectionIndex]) {
    headers.push(toc[sectionIndex].title);
    var subs = toc[sectionIndex].subheaders || [];
    for (var i = Math.max(0, (subheaderIndex || 0) - 2); i < Math.min(subs.length, (subheaderIndex || 0) + 3); i++) headers.push(subs[i]);
  }
  if (toc[sectionIndex - 1]) headers.push(toc[sectionIndex - 1].title);
  if (toc[sectionIndex + 1]) headers.push(toc[sectionIndex + 1].title);
  return headers;
}

// ============================================
// MAIN PIPELINE
// ============================================
function initializeGeneration(params) {
  params = params || {};
  var cn = params.courseName, ts = params.totalPages, tocText = params.tableOfContents;
  var un = params.userName, ue = params.userEmail, imgOn = params.imagesEnabled !== false;
  var courseMode = String(params.courseMode || 'custom').toLowerCase() === 'rms' ? 'rms' : 'custom';
  var rmsCourseName = String(params.rmsCourseName || (courseMode === 'rms' ? cn : '') || '').trim();
  var rmsCourseId = String(params.rmsCourseId || '').trim();
  var storeToDb = courseMode === 'rms';
  if (!cn || !cn.trim()) return { success: false, message: 'Title required', logs: [] };
  if (courseMode === 'rms' && !rmsCourseName) return { success: false, message: 'Please select an RMS course from the dropdown.', logs: [] };
  if (!tocText || !tocText.trim()) return { success: false, message: 'TOC required', logs: [] };

  var logs = [], jobId = Utilities.getUuid();
  logs.push({ time: new Date().toLocaleTimeString(), message: 'Parsing TOC...', type: 'info' });
  logs.push({ time: new Date().toLocaleTimeString(), message: 'Mode: HTML Coursebook with GPT Image 2 persistent base64 visuals', type: 'info' });
  logs.push({ time: new Date().toLocaleTimeString(), message: 'Images: ' + (imgOn ? 'ON (header-aware mixed visuals + base64 backup)' : 'OFF'), type: 'info' });
  logs.push({ time: new Date().toLocaleTimeString(), message: 'Course source: ' + (storeToDb ? 'RMS course — DB upload enabled' : 'Custom course — DB upload skipped'), type: 'info' });

  var toc = normalizeTocStructure(parseTOC(tocText));
  if (!toc.length) return { success: false, message: 'Could not parse TOC', logs: logs };

  var req = Math.min(parseInt(ts, 10) || 100, CONFIG.MAX_TOTAL_PAGES);
  var alloc = calculatePageAllocation(req, toc);

  logs.push({ time: new Date().toLocaleTimeString(), message: toc.length + ' sections, ' + alloc.totalSubheaders + ' subtopics', type: 'info' });
  logs.push({ time: new Date().toLocaleTimeString(), message: 'Target pages: ' + req + ' | planned page blocks: ' + alloc.estimatedTotal, type: Math.abs(alloc.estimatedTotal - req) <= Math.max(2, Math.ceil(req * 0.1)) ? 'success' : 'info' });
  logs.push({ time: new Date().toLocaleTimeString(), message: 'Images: ' + (imgOn ? 'ON — content shortened so image pages stay closer to target' : 'OFF — no image prompts/API calls will run'), type: imgOn ? 'info' : 'success' });

  var chunksPerSubheader = Math.max(1, Math.round(alloc.pagesPerSubheader || 1));
  var chunkPlan = alloc.chunkPlan || [];
  var totalTasks = 1; // cover+toc
  var planIdx = 0;
  for (var i = 0; i < toc.length; i++) {
    totalTasks += 1; // overview
    var subCount = Math.max(1, toc[i].subheaders.length);
    for (var sp = 0; sp < subCount; sp++) totalTasks += Math.max(1, parseInt(chunkPlan[planIdx++], 10) || chunksPerSubheader);
  }
  totalTasks += 1; // recap
  var contentWordsPerGeneratedPage = imgOn ? (CONFIG.WORDS_PER_PAGE_WITH_IMAGES || 180) : CONFIG.WORDS_PER_PAGE;

  // Log to spreadsheet FIRST so the Resume button appears the instant the row exists —
  // even if the user closes the tab in the next second.
  var ulr = logUserToSpreadsheet(un, ue, cn, jobId, JSON.stringify({
    courseName: cn, totalPages: req, tableOfContents: tocText, imagesEnabled: imgOn,
    courseMode: courseMode, rmsCourseName: rmsCourseName, rmsCourseId: rmsCourseId, storeToDb: storeToDb
  }));

  var htmlHeader = generateHTMLHeader(cn);

  var job = {
    id: jobId, courseName: cn, userName: un || '', userEmail: ue || '',
    courseMode: courseMode, rmsCourseName: rmsCourseName, rmsCourseId: rmsCourseId, storeToDb: storeToDb,
    imagesEnabled: imgOn, userLogRow: ulr.success ? ulr.row : null,
    totalPages: req, allocation: alloc, chunksPerSubheader: chunksPerSubheader, chunkPlan: chunkPlan,
    contentWordsPerGeneratedPage: contentWordsPerGeneratedPage,
    tocStructure: toc, currentTask: 0, totalTasks: totalTasks,
    status: 'initialized',
    costs: { textInputTokens: 0, textOutputTokens: 0, imagesGenerated: 0, textCost: 0, imageCost: 0, totalCost: 0 }
  };

  // Save slim state + header to Drive RIGHT NOW so resume works even if the very next call dies.
  saveJobState(jobId, job, true);
  try { backupHtmlHeader(jobId, htmlHeader); } catch (e) { }

  return { success: true, jobId: jobId, totalTasks: totalTasks, logs: logs, htmlHeader: htmlHeader };
}

/**
 * v9.1: builds ONE chunk per call, backs it up to Drive immediately (with base64 images),
 * and saves slim job state to Drive every task. No accumulation in memory/cache.
 */
function processNextChunk(jobId) {
  var job = loadJobState(jobId);
  if (!job) return { success: false, done: false, error: 'Job not found', logs: [], htmlChunk: '' };

  var logs = [], ct = job.currentTask, toc = normalizeTocStructure(job.tocStructure);
  var alloc = job.allocation || { pagesPerSubheader: CONFIG.MIN_PAGES_PER_SUBHEADER };
  var imgOn = job.imagesEnabled === true;
  var chunkPlan = Array.isArray(job.chunkPlan) ? job.chunkPlan : (alloc && Array.isArray(alloc.chunkPlan) ? alloc.chunkPlan : null);
  var contentWordsPerGeneratedPage = parseInt(job.contentWordsPerGeneratedPage, 10) || (imgOn ? (CONFIG.WORDS_PER_PAGE_WITH_IMAGES || 180) : CONFIG.WORDS_PER_PAGE);
  var deadlineMs = Date.now() + (CONFIG.CHUNK_TIME_BUDGET_MS || 270000);
  if (!alloc.pagesPerSubheader || isNaN(alloc.pagesPerSubheader)) alloc.pagesPerSubheader = CONFIG.MIN_PAGES_PER_SUBHEADER;

  var chunkParts = []; // built in THIS call only, not persisted in job state

  try {
    if (ct === 0) {
      // ── COVER + TOC ──
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Creating cover + table of contents...', type: 'info' });
      var header = generateHTMLHeader(job.courseName);
      try { backupHtmlHeader(jobId, header); } catch (e) { }
      chunkParts.push(generateCoverPage(job.courseName));
      chunkParts.push(generateTableOfContentsPage(toc, alloc.pagesPerSubheader));
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Cover + TOC done', type: 'success' });

    } else if (ct === job.totalTasks - 1) {
      // ── RECAP ──
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Generating course recap...', type: 'info' });
      var rr = generateRecapContent(toc, job.courseName);
      job.costs.textInputTokens += rr.usage.inputTokens;
      job.costs.textOutputTokens += rr.usage.outputTokens;
      chunkParts.push(generateRecapPageHtml(rr.content, job.courseName));
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Recap done', type: 'success' });

    } else {
      var ti = getTaskInfo(ct, toc, job.chunksPerSubheader, chunkPlan);

      if (ti.type === 'overview') {
        var sec = toc[ti.sectionIndex] || { title: 'Untitled Section', subheaders: [] };
        sec.subheaders = Array.isArray(sec.subheaders) ? sec.subheaders : [];
        logs.push({ time: new Date().toLocaleTimeString(), message: 'Section ' + (ti.sectionIndex + 1) + ': ' + sec.title, type: 'info' });
        var ov = generateSectionOverview(sec.title, sec.subheaders);
        job.costs.textInputTokens += ov.usage.inputTokens;
        job.costs.textOutputTokens += ov.usage.outputTokens;

        var imageUrl = '';
        if (imgOn) {
          logs.push({ time: new Date().toLocaleTimeString(), message: '  Generating section image (base64, persistent)...', type: 'info' });
          var nearbyHeaders = getNearbyHeadersForVisual(toc, ti.sectionIndex, 0);
          var overviewVisualType = chooseVisualType(sec.title + ' ' + nearbyHeaders.join(' '), 'overview', ti.sectionIndex);
          var ir = generateSectionImage(sec.title, job.courseName + ' / ' + sec.subheaders.join(' | '), deadlineMs, overviewVisualType, nearbyHeaders);
          imageUrl = ir.url;
          if (ir.analysisUsage) { job.costs.textInputTokens += ir.analysisUsage.inputTokens; job.costs.textOutputTokens += ir.analysisUsage.outputTokens; }
          if (isRealGeneratedImage(imageUrl)) job.costs.imagesGenerated++;
          logs.push({ time: new Date().toLocaleTimeString(), message: '  Visual (' + (ir.visualType || overviewVisualType) + '): ' + (isRealGeneratedImage(imageUrl) ? 'OK (embedded)' : 'placeholder'), type: isRealGeneratedImage(imageUrl) ? 'success' : 'info' });
        }
        chunkParts.push(generateOverviewPageHtml(sec.title, ov.content, imageUrl, ti.sectionIndex + 1));

      } else if (ti.type === 'content') {
        var sec = toc[ti.sectionIndex] || { title: 'Untitled Section', subheaders: [] };
        sec.subheaders = Array.isArray(sec.subheaders) ? sec.subheaders : [];
        var subheader = sec.subheaders[ti.subheaderIndex] || sec.title;
        var chunkIndex = ti.chunkIndex;
        var totalChunks = ti.totalChunksForSubheader || job.chunksPerSubheader;
        logs.push({ time: new Date().toLocaleTimeString(), message: 'Generating: ' + subheader + ' (page block ' + (chunkIndex + 1) + '/' + totalChunks + ')', type: 'info' });

        var cr = generateSubheaderContent(subheader, sec.title, job.courseName, chunkIndex, totalChunks, totalChunks, contentWordsPerGeneratedPage);
        job.costs.textInputTokens += cr.usage.inputTokens;
        job.costs.textOutputTokens += cr.usage.outputTokens;

        var imageSide = (chunkIndex % 2 === 0) ? 'left' : 'right';
        var mainImageUrl = '', sideImageUrl = '';

        if (imgOn) {
          logs.push({ time: new Date().toLocaleTimeString(), message: '  Generating main image (base64, persistent)...', type: 'info' });
          var nearbyHeaders = getNearbyHeadersForVisual(toc, ti.sectionIndex, ti.subheaderIndex);
          var mainVisualType = chooseVisualType(subheader + ' ' + sec.title, 'content', chunkIndex);
          var mainIr = generateSectionImage(subheader, sec.title + ' / Course: ' + job.courseName, deadlineMs, mainVisualType, nearbyHeaders);
          mainImageUrl = mainIr.url;
          if (mainIr.analysisUsage) { job.costs.textInputTokens += mainIr.analysisUsage.inputTokens; job.costs.textOutputTokens += mainIr.analysisUsage.outputTokens; }
          if (isRealGeneratedImage(mainImageUrl)) job.costs.imagesGenerated++;

          if (Date.now() < deadlineMs - 30000) {
            logs.push({ time: new Date().toLocaleTimeString(), message: '  Generating ' + imageSide + '-side image (base64, persistent)...', type: 'info' });
            var sideVisualType = chooseVisualType(subheader + ' ' + sec.title, 'side', chunkIndex + 1);
            var sideIr = generateSmallContextImage(subheader, sec.title + ' / Course: ' + job.courseName, deadlineMs, sideVisualType, nearbyHeaders);
            sideImageUrl = sideIr.url;
            if (sideIr.analysisUsage) { job.costs.textInputTokens += sideIr.analysisUsage.inputTokens; job.costs.textOutputTokens += sideIr.analysisUsage.outputTokens; }
            if (isRealGeneratedImage(sideImageUrl)) job.costs.imagesGenerated++;
          }

          logs.push({ time: new Date().toLocaleTimeString(), message: '  Mixed visual types embedded as base64 — will survive URL expiry', type: 'success' });
        }

        chunkParts.push(generateSingleChunkHtml(subheader, cr.content, mainImageUrl, sideImageUrl, imageSide, ti.sectionIndex + 1, ti.subheaderIndex + 1, chunkIndex, imgOn));
        logs.push({ time: new Date().toLocaleTimeString(), message: '  Chunk ' + (chunkIndex + 1) + '/' + totalChunks + ' complete', type: 'success' });
      }
    }

    job.currentTask = ct + 1;
    var done = job.currentTask >= job.totalTasks;
    if (done) {
      job.status = 'complete';
      job.costs.textCost = (job.costs.textInputTokens / 1e6) * CONFIG.PRICING.TEXT_INPUT_PER_1M + (job.costs.textOutputTokens / 1e6) * CONFIG.PRICING.TEXT_OUTPUT_PER_1M;
      job.costs.imageCost = job.costs.imagesGenerated * CONFIG.PRICING.GPT_IMAGE_2_MEDIUM_1024;
      job.costs.totalCost = job.costs.textCost + job.costs.imageCost;
      logCostToSpreadsheet(job.costs, job.courseName);
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Done! ' + job.costs.imagesGenerated + ' images, $' + job.costs.totalCost.toFixed(4), type: 'success' });
    }

    var htmlChunk = chunkParts.join('\n');

    // v9.1: save slim job state to Drive on EVERY task so resume always works, even if window closes next millisecond.
    saveJobState(jobId, job, true);

    // v9.1: back up chunk to Drive with base64 images embedded — survives session/URL expiry.
    if (htmlChunk.length > 0) {
      try { backupChunkHtml(jobId, ct, htmlChunk); } catch (e) { }
    }

    return { success: true, done: done, currentTask: job.currentTask, totalTasks: job.totalTasks, logs: logs, htmlChunk: htmlChunk };

  } catch (err) {
    logs.push({ time: new Date().toLocaleTimeString(), message: 'Error: ' + err.toString(), type: 'error' });
    if (job.userLogRow) { try { updateUserLogStatus(job.userLogRow, 'Error: ' + err.toString().substring(0, 100)); } catch(e2) {} }
    saveJobState(jobId, job, true);
    return { success: false, done: false, error: err.toString(), currentTask: job.currentTask, totalTasks: job.totalTasks, logs: logs, htmlChunk: '' };
  }
}

/**
 * v9.1: assembles the final coursebook from Drive backup chunks (the single source of truth).
 * Images are all base64 — no URL expiry — so the final HTML is a complete, self-contained coursebook.
 */
function getGeneratedHTML(jobId) {
  var job = loadJobState(jobId);
  if (!job) return { success: false, html: '', message: 'Job not found' };
  if (job.status !== 'complete') return { success: false, html: '', message: 'Not complete' };

  var dbPending = shouldStoreCoursebookToDb_(job);
  var dbStatusMessage = dbPending
    ? 'PDF uploaded in DB: PENDING — click Download PDF. The app will generate the PDF and upload it to RMS/GHL DB automatically.'
    : 'PDF uploaded in DB: NO — custom course selected, DB upload will be skipped.';

  // The live iframe on the client already has the full HTML (base64 images and all).
  // The actual PDF exists only after the browser renders it, so DB upload starts immediately after Download PDF generates the PDF blob.
  return {
    success: true,
    html: '',
    fileUrl: '',
    fileId: '',
    pdfBase64: '',
    pdfFileName: '',
    dbUploadPending: dbPending,
    message: 'Coursebook generated successfully. ' + dbStatusMessage
  };
}

/**
 * v9.1: server-side full HTML assembly from Drive backups — used ONLY when the client iframe
 * is not available (e.g. headless download). Returns the complete coursebook with embedded images.
 */
function assembleFullCoursebookFromBackups(jobId) {
  try {
    var job = loadJobState(jobId);
    if (!job) return { success: false, message: 'Job not found' };

    var headerResult = loadHtmlHeader(jobId);
    var header = headerResult.success ? headerResult.html : generateHTMLHeader(job.courseName || 'Coursebook');

    var info = getHtmlBackupInfo(jobId);
    if (!info.found) return { success: false, message: 'No backup chunks found on Drive' };

    var parts = [header];
    for (var i = 0; i < info.taskNums.length; i++) {
      var c = loadBackupHtmlChunk(jobId, info.taskNums[i]);
      if (c.success) parts.push(c.html);
    }
    parts.push('</body>\n</html>');

    return { success: true, html: parts.join('\n'), chunkCount: info.chunkCount };
  } catch (e) {
    return { success: false, message: e.toString() };
  }
}

/**
 * Called by client after successful download to clean up Drive backups.
 */
function cleanupCompletedJob(jobId) {
  try { deleteJobState(jobId); } catch (e) { }
  try { cleanupHtmlBackups(jobId); } catch (e) { }
  try { cleanupSourcePdfPages(jobId); } catch (e) { }
  return { success: true };
}

function logStoppedGeneration(jobId, pageCount) {
  try {
    var job = loadJobState(jobId);
    if (job && job.userLogRow) {
      updateUserLogStopped(job.userLogRow, pageCount);
      job.status = 'stopped';
      saveJobState(jobId, job, true);
    }
    return { success: true };
  } catch (e) { return { success: false, message: e.toString() }; }
}

// ============================================
// DASHBOARD DATA
// ============================================
function fetchUserDashboardData(userName) {
  try {
    if (!userName || !userName.trim()) return { success: false, message: 'Please select your name first.' };
    var ssId = CONFIG.USER_LOGS_SPREADSHEET_ID;
    if (!ssId) return { success: false, message: 'No spreadsheet configured.' };
    var ss = SpreadsheetApp.openById(ssId);
    var sheet = ss.getSheetByName(CONFIG.USER_LOGS_SHEET_NAME);
    if (!sheet) return { success: false, message: 'Sheet not found.' };
    var lastRow = sheet.getLastRow();
    if (lastRow < 2) return { success: true, rows: [], stats: { total: 0, completed: 0, stopped: 0, errors: 0, generating: 0, totalCost: 0 } };
    // v9.1: always read 10 columns so hasConfig is populated correctly even on legacy rows
    var numCols = 10;
    var data = sheet.getRange(2, 1, lastRow - 1, numCols).getValues();
    var rows = [], stats = { total: 0, completed: 0, stopped: 0, errors: 0, generating: 0, totalCost: 0 };
    for (var i = 0; i < data.length; i++) {
      var name = (data[i][1] || '').toString().trim();
      if (name !== userName.trim()) continue;
      var timestamp = (data[i][0] || '').toString();
      var title = (data[i][3] || '').toString();
      var driveLink = (data[i][4] || '').toString();
      var downloadLink = (data[i][5] || '').toString();
      var status = (data[i][6] || '').toString();
      var cost = (data[i][7] || '').toString();
      var storedJobId = (data[i][8] || '').toString().trim();
      var configRaw = data[i][9] ? data[i][9].toString().trim() : '';
      var hasConfig = configRaw.length > 2;
      stats.total++;
      var sl = status.toLowerCase();
      if (sl.indexOf('completed') !== -1) stats.completed++;
      else if (sl.indexOf('stopped') !== -1) stats.stopped++;
      else if (sl.indexOf('error') !== -1) stats.errors++;
      else if (sl.indexOf('generating') !== -1) stats.generating++;
      var costNum = parseFloat(cost.replace(/[^0-9.\-]/g, ''));
      if (!isNaN(costNum)) stats.totalCost += costNum;

      // v9.2: Resume is available for ANY unfinished row that has a job ID or config we can rehydrate from.
      // A row is "finished" ONLY if it was actually completed OR explicitly restarted.
      // The presence of "+ Downloaded" in the status does NOT mean generation is done — the user might
      // have downloaded a partial coursebook during generation. The base state (Generating/Stopped/Error)
      // is what decides resumability.
      var isCompleted = sl.indexOf('completed') !== -1;           // true completion
      var isRestarted = sl.indexOf('restarted') !== -1;           // already resumed elsewhere
      var isFinished  = isCompleted || isRestarted;
      var canResume   = !isFinished && (hasConfig || (storedJobId && storedJobId.length > 10));

      rows.push({ rowNum: i + 2, timestamp: timestamp, name: name, email: (data[i][2] || '').toString(), title: title, driveLink: driveLink, downloadLink: downloadLink, status: status, cost: cost, canResume: canResume, storedJobId: storedJobId });
    }
    rows.reverse();
    return { success: true, rows: rows, stats: stats };
  } catch (e) { return { success: false, message: e.toString() }; }
}

function getResumeConfig(rowNum) {
  try {
    var ss = SpreadsheetApp.openById(CONFIG.USER_LOGS_SPREADSHEET_ID);
    var sheet = ss.getSheetByName(CONFIG.USER_LOGS_SHEET_NAME);
    if (!sheet) return { success: false, message: 'Sheet not found.' };
    // v9.1: always read 10 cols
    var storedJobId = (sheet.getRange(rowNum, 9).getValue() || '').toString().trim();
    var configStr = (sheet.getRange(rowNum, 10).getValue() || '').toString().trim();

    // If config isn't in the spreadsheet, try to rehydrate from the Drive job file
    if (!configStr || configStr.length < 3) {
      if (storedJobId) {
        var job = loadJobState(storedJobId);
        if (job) {
          // Reconstruct TOC text from stored structure
          var tocText = '';
          var toc = normalizeTocStructure(job.tocStructure);
          for (var i = 0; i < toc.length; i++) {
            tocText += (i + 1) + '. ' + toc[i].title + '\n';
            for (var s = 0; s < toc[i].subheaders.length; s++) tocText += '   - ' + toc[i].subheaders[s] + '\n';
          }
          return {
            success: true,
            storedJobId: storedJobId,
            config: {
              mode: job.mode || 'coursebook',
              courseName: job.courseName || '',
              totalPages: job.totalPages || 100,
              tableOfContents: tocText.trim(),
              imagesEnabled: job.imagesEnabled !== false,
              courseMode: job.courseMode || 'custom',
              rmsCourseName: job.rmsCourseName || '',
              rmsCourseId: job.rmsCourseId || '',
              storeToDb: job.storeToDb === true
            }
          };
        }
      }
      return { success: false, message: 'No saved config.' };
    }

    var config;
    try { config = JSON.parse(configStr); } catch (pe) { return { success: false, message: 'Config corrupted.' }; }
    return { success: true, storedJobId: storedJobId, config: {
      mode: config.mode || 'coursebook',
      courseName: config.courseName || config.title || '',
      totalPages: config.totalPages || 100,
      tableOfContents: config.tableOfContents || '',
      imagesEnabled: config.imagesEnabled !== false,
      courseMode: config.courseMode || 'custom',
      rmsCourseName: config.rmsCourseName || '',
      rmsCourseId: config.rmsCourseId || '',
      storeToDb: config.storeToDb === true
    } };
  } catch (e) { return { success: false, message: e.toString() }; }
}

function markRowRestarted(rowNum) {
  try {
    var ss = SpreadsheetApp.openById(CONFIG.USER_LOGS_SPREADSHEET_ID);
    var sheet = ss.getSheetByName(CONFIG.USER_LOGS_SHEET_NAME); if (!sheet) return;
    var cur = (sheet.getRange(rowNum, 7).getValue() || '').toString();
    sheet.getRange(rowNum, 7).setValue('Restarted (' + cur + ')');
  } catch (e) { }
}

function checkJobInCache(storedJobId) {
  try {
    if (!storedJobId) return { alive: false };
    var job = loadJobState(storedJobId);
    if (!job) return { alive: false };
    return { alive: true, currentTask: job.currentTask || 0, totalTasks: job.totalTasks || 1, courseName: job.courseName || '', status: job.status || 'unknown' };
  } catch (e) { return { alive: false }; }
}

function getHtmlBackupInfoForClient(jobId) { return getHtmlBackupInfo(jobId); }
function loadBackupHtmlChunkForClient(jobId, taskNum) { return loadBackupHtmlChunk(jobId, taskNum); }
