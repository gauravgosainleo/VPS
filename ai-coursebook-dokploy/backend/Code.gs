function fetchRmsCourseList_() {
  var cfg = CONFIG.RMS_COURSE_LIST_API || {};
  var token = getRmsCourseListApiToken_(false);
  var base = String(cfg.BASE_URL || '').replace(/\/+$/, '');
  var url = base + '/api/Kites/Operator/common?apikey=' + encodeURIComponent(cfg.API_KEY) +
    '&accessToken=' + encodeURIComponent(token.accessToken) +
    '&deviceToken=' + encodeURIComponent(token.deviceToken);

  function callApi() {
    return UrlFetchApp.fetch(url, {
      method: 'post', contentType: 'application/json', headers: { 'Accept': 'application/json' },
      payload: JSON.stringify({}), muteHttpExceptions: true
    });
  }

  var response = callApi();
  var code = response.getResponseCode();
  var parsed = _parseJsonResponse_(response);
  if ((code === 401 || code === 403 || (parsed.json && parsed.json.statuscode && parsed.json.statuscode !== 200)) && (!parsed.json || !parsed.json.content)) {
    token = getRmsCourseListApiToken_(true);
    url = base + '/api/Kites/Operator/common?apikey=' + encodeURIComponent(cfg.API_KEY) +
      '&accessToken=' + encodeURIComponent(token.accessToken) +
      '&deviceToken=' + encodeURIComponent(token.deviceToken);
    response = callApi();
    code = response.getResponseCode();
    parsed = _parseJsonResponse_(response);
  }
  if (code < 200 || code >= 300 || !parsed.json || parsed.json.statuscode !== 200) {
    throw new Error('Get RMS Course List API failed. HTTP ' + code + ': ' + (parsed.raw || '').substring(0, 300));
  }

  var rows = _contentToRows_(parsed.json.content);
  var seen = {};
  var courses = [];
  for (var i = 0; i < rows.length; i++) {
    var row = rows[i] || {};
    var courseName = String(_getFieldIgnoreCase_(row, 'Course') || _getFieldIgnoreCase_(row, 'courseName') || _getFieldIgnoreCase_(row, 'CourseName') || '').trim();
    if (!courseName) continue;
    var key = courseName.toLowerCase();
    if (seen[key]) continue;
    seen[key] = true;
    courses.push({
      courseId: String(_getFieldIgnoreCase_(row, 'Courseid') || _getFieldIgnoreCase_(row, 'courseId') || _getFieldIgnoreCase_(row, 'CourseId') || '').trim(),
      courseName: courseName,
      courseURL: String(_getFieldIgnoreCase_(row, 'course_url') || _getFieldIgnoreCase_(row, 'courseURL') || _getFieldIgnoreCase_(row, 'CourseURL') || '').trim(),
      vendorId: String(_getFieldIgnoreCase_(row, 'vendor_id') || _getFieldIgnoreCase_(row, 'vendorId') || '').trim(),
      vendorName: String(_getFieldIgnoreCase_(row, 'vendor_name') || _getFieldIgnoreCase_(row, 'vendorName') || '').trim()
    });
  }
  courses.sort(function(a, b) { return a.courseName.localeCompare(b.courseName); });
  return courses;
}

function fetchRmsCourseList() {
  try {
    var cacheKey = 'coursebook_full_course_list_v1';
    try { var cached = CacheService.getScriptCache().get(cacheKey); if (cached) return { success: true, courses: JSON.parse(cached), cached: true }; } catch (e) {}
    var courses = fetchRmsCourseList_();
