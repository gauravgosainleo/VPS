    return { success: true, courses: courses };
  } catch (e) {
    return { success: false, message: e.toString(), courses: [] };
  }
}

function shouldStoreCoursebookToDb_(jobOrMode) {
  if (!jobOrMode) return false;
  if (typeof jobOrMode === 'string') return String(jobOrMode).toLowerCase() === 'rms';
  if (jobOrMode.storeToDb === false) return false;
  return String(jobOrMode.courseMode || '').toLowerCase() === 'rms';
}

function _buildGhlCoursebookPayload_(pdfBlob, safeCourseName, emp) {
  var cfg = CONFIG.GHL_UPLOAD_API || {};
  return {
    courseName: safeCourseName,
    qmsTypeId: String(cfg.QMS_TYPE_ID || 31),
    description: cfg.DESCRIPTION || 'AI Generated Coursebook',
    trainerId: emp.empCode,
    isPublic: String(cfg.IS_PUBLIC !== false),
    shortDescription: cfg.SHORT_DESCRIPTION || 'Auto-generated by AI Coursebook Generator',
    file: pdfBlob
  };
}

function _postGhlContentPayload_(payload) {
  var cfg = CONFIG.GHL_UPLOAD_API || {};
  return UrlFetchApp.fetch(cfg.URL, { method: 'post', headers: { 'X-Api-Key': cfg.API_KEY }, payload: payload, muteHttpExceptions: true });
}

function _readGhlOutcome_(response) {
  var httpCode = response.getResponseCode();
  var parsed = _parseJsonResponse_(response);
  var raw = parsed.raw || '';
  var json = parsed.json || null;
  var message = '';
  if (json) message = json.message || json.Message || json.error || json.Error || json.status || json.Status || '';
  var okByHttp = httpCode >= 200 && httpCode < 300;
  var okByJson = !json || json.success === true || json.statuscode === 200 || json.statusCode === 200 || json.StatusCode === 200;
  if (json && json.success === false) okByJson = false;
  var courseNotFound = /course\s+not\s+found/i.test(raw) || /course\s+not\s+found/i.test(String(message));
  return { success: !!(okByHttp && okByJson), httpCode: httpCode, json: json, raw: raw, message: message, courseNotFound: courseNotFound };
}

function _shortApiText_(outcome) {
  if (!outcome) return '';
  return String(outcome.raw || outcome.message || '').substring(0, 600);
}

function uploadCoursebookPdfBlobToDb_(pdfBlob, courseName, userEmail) {
  if (!pdfBlob) throw new Error('PDF file blob is required for DB upload.');
  var email = String(userEmail || '').trim();
  if (!email) throw new Error('User email is required for DB upload.');
  var emp = fetchEmpCodeByEmail_(email);
  var safeCourseName = String(courseName || '').trim();
  if (!safeCourseName) throw new Error('RMS course name is required for DB upload.');
  if (!pdfBlob.getName || !pdfBlob.getName()) pdfBlob.setName(_safeCoursebookFilename_(safeCourseName));
  var payload = _buildGhlCoursebookPayload_(pdfBlob, safeCourseName, emp);
  var response = _postGhlContentPayload_(payload);
  var outcome = _readGhlOutcome_(response);
  if (!outcome.success) {
    var detail = _shortApiText_(outcome);
    if (outcome.courseNotFound) detail += ' | Select an exact RMS course from the dropdown, or choose Custom course to download without DB upload.';
    throw new Error('GHL DB upload failed. HTTP ' + outcome.httpCode + ': ' + detail);
  }
  return {
    success: true,
    message: 'File is now stored in DB.',
    courseName: safeCourseName,
    empCode: emp.empCode,
    employeeName: emp.employeeName,
    officialEmail: emp.officialEmail,
    httpCode: outcome.httpCode,
    response: outcome.json || outcome.raw
  };
}

function finalizeCoursebookPdf(jobId, pdfBase64, courseName, userName, userEmail, courseMode, rmsCourseName) {
  var logs = [];
  function pushLog(message, type) {
    logs.push({ time: new Date().toLocaleTimeString(), message: message, type: type || 'info' });
  }

  var job = null;
  try {
    if (jobId) job = loadJobState(jobId);
  } catch (jobLoadErr) {
    // DB upload must not depend on Drive/job-state access. If DriveApp is not authorized,
    // continue with the parameters sent by the browser and report the job-state issue only in logs.
    pushLog('Job state could not be loaded, continuing DB upload from browser data: ' + jobLoadErr.toString(), 'info');
  }

  try {
    var effectiveCourseName = String(rmsCourseName || courseName || (job && job.rmsCourseName) || (job && job.courseName) || 'Coursebook').trim();
    var effectiveEmail = String(CONFIG.DB_UPLOAD_OFFICIAL_EMAIL || '').trim();
    var effectiveMode = String(courseMode || (job && job.courseMode) || 'custom').toLowerCase() === 'rms' ? 'rms' : 'custom';

    pushLog('PDF generated. Starting final DB upload check for: ' + effectiveCourseName, 'info');
    pushLog('Course mode: ' + (effectiveMode === 'rms' ? 'RMS course — DB upload enabled' : 'Custom course — DB upload skipped'), effectiveMode === 'rms' ? 'info' : 'success');

    if (!pdfBase64) throw new Error('PDF base64 is missing. DB upload cannot continue.');

    // Build the PDF blob once from the browser-generated PDF. This is used directly for RMS/GHL upload.
    // Important: DB upload is NOT dependent on DriveApp. Drive save is optional and runs after DB upload.
    var pdfBlob = makePdfBlobFromBase64_(pdfBase64, effectiveCourseName);
    if (!pdfBlob.getName || !pdfBlob.getName()) pdfBlob.setName(_safeCoursebookFilename_(effectiveCourseName));

    var drive = { success: false, skipped: true, message: 'Drive save not required for DB upload.' };
    var dbUpload = { success: false, skipped: true, message: effectiveMode === 'rms' ? 'DB upload skipped.' : 'Custom course selected; DB upload skipped.' };

    if (effectiveMode === 'rms') {
      try {
        if (!effectiveCourseName) throw new Error('RMS course name is required for DB upload.');
        if (!effectiveEmail) throw new Error('Fixed DB upload email is missing in CONFIG.DB_UPLOAD_OFFICIAL_EMAIL.');

        pushLog('Fetching EmpCode for fixed DB upload email: ' + effectiveEmail, 'info');
        var emp = fetchEmpCodeByEmail_(effectiveEmail);
        pushLog('EmpCode found: ' + emp.empCode + (emp.employeeName ? ' (' + emp.employeeName + ')' : ''), 'success');

        pushLog('Uploading PDF to RMS/GHL DB with qmsTypeId=' + (CONFIG.GHL_UPLOAD_API.QMS_TYPE_ID || 31) + '...', 'info');
        var payload = _buildGhlCoursebookPayload_(pdfBlob, effectiveCourseName, emp);
        var response = _postGhlContentPayload_(payload);
        var outcome = _readGhlOutcome_(response);

        if (!outcome.success) {
          var detail = _shortApiText_(outcome);
          if (outcome.courseNotFound) detail += ' | Select an exact RMS course from the dropdown, or choose Custom course to download without DB upload.';
          throw new Error('GHL DB upload failed. HTTP ' + outcome.httpCode + ': ' + detail);
        }

        dbUpload = {
          success: true,
          skipped: false,
          message: 'File is now stored in DB.',
          courseName: effectiveCourseName,
          empCode: emp.empCode,
          employeeName: emp.employeeName,
          officialEmail: emp.officialEmail,
          qmsTypeId: CONFIG.GHL_UPLOAD_API.QMS_TYPE_ID || 31,
          httpCode: outcome.httpCode,
          response: outcome.json || outcome.raw
        };
        pushLog('PDF uploaded in DB: YES — File is now stored in DB.', 'success');
        try { if (job && job.userLogRow) updateUserLogStatus(job.userLogRow, 'Completed + DB stored'); } catch (statusErr1) {}
      } catch (dbErr) {
        dbUpload = { success: false, skipped: false, message: dbErr.toString() };
        pushLog('PDF uploaded in DB: NO — DB upload failed: ' + dbErr.toString(), 'error');
        try { if (job && job.userLogRow) updateUserLogStatus(job.userLogRow, 'Completed (DB upload failed)'); } catch (statusErr2) {}
        Logger.log('Coursebook DB upload failed for job ' + jobId + ': ' + dbErr.toString());
      }
    } else {
      dbUpload = { success: false, skipped: true, message: 'Custom course selected; DB upload skipped.' };
      pushLog('PDF uploaded in DB: NO — Custom course selected, DB upload skipped.', 'success');
      try { if (job && job.userLogRow) updateUserLogStatus(job.userLogRow, 'Completed (Custom course - DB skipped)'); } catch (statusErr3) {}
    }

    // Optional Drive save. This must never block DB upload or change DB upload result.
    // In some deployments, DriveApp is not authorized; we log it as optional failure only.
    try {
      pushLog('Optional Drive save: attempting to save a copy...', 'info');
      var driveBlob = makePdfBlobFromBase64_(pdfBase64, effectiveCourseName);
      drive = savePdfBlobToDrive_(driveBlob, effectiveCourseName);
      if (drive && drive.success) {
        pushLog('Optional Drive save completed: ' + (drive.filename || ''), 'success');
        try { if (job && job.userLogRow) updateUserLogWithFileLink(job.userLogRow, drive.fileUrl, job.costs ? job.costs.totalCost : undefined); } catch (linkErr) {}
      } else {
        pushLog('Optional Drive save skipped/failed: ' + ((drive && drive.message) || 'Unknown'), 'info');
      }
    } catch (driveErr) {
      drive = { success: false, skipped: true, message: driveErr.toString() };
      pushLog('Optional Drive save failed, but DB upload result above is final: ' + driveErr.toString(), 'info');
    }

    try { if (job && job.userLogRow) updateUserLogWithDownload(job.userLogRow, (drive && drive.filename) || _safeCoursebookFilename_(effectiveCourseName)); } catch (downloadErr) {}
    try {
      if (job && job.userLogRow) {
        if (dbUpload && dbUpload.success) updateUserLogStatus(job.userLogRow, 'Completed + Downloaded + DB stored');
        else if (dbUpload && dbUpload.skipped) updateUserLogStatus(job.userLogRow, 'Completed + Downloaded (DB skipped)');
        else updateUserLogStatus(job.userLogRow, 'Completed + Downloaded (DB upload failed)');
      }
    } catch (statusErr4) {}

    if (job) {
      try {
        job.fileUrl = (drive && drive.fileUrl) || job.fileUrl || '';
        job.dbUploadResult = dbUpload;
        job.status = 'complete';
        saveJobState(jobId, job, true);
      } catch (saveStateErr) {
        pushLog('Job state update skipped: ' + saveStateErr.toString(), 'info');
      }
    }

    var msg = '';
    if (dbUpload && dbUpload.success) msg = 'PDF uploaded in DB: YES — File is now stored in DB.';
    else if (dbUpload && dbUpload.skipped) msg = 'PDF uploaded in DB: NO — custom course selected, upload skipped.';
    else msg = 'PDF uploaded in DB: NO — DB upload failed: ' + (dbUpload.message || 'Unknown');

    return {
      success: true,
      fileUrl: (drive && drive.fileUrl) || '',
      fileId: (drive && drive.fileId) || '',
      filename: (drive && drive.filename) || _safeCoursebookFilename_(effectiveCourseName),
      message: msg,
      dbUpload: dbUpload,
      drive: drive,
      logs: logs
    };
  } catch (e) {
    pushLog('Final DB upload step failed: ' + e.toString(), 'error');
    return { success: false, message: e.toString(), logs: logs };
  }
}

