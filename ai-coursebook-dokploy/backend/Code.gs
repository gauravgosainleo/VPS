    var existing = folder.getFilesByName(fname);
    if (existing.hasNext()) existing.next().setContent(json);
    else folder.createFile(fname, json, 'application/json');
    return { success: true };
  } catch (e) {
    return { success: false, message: e.toString() };
  }
}

function loadSourcePdfPage(jobId, pageNum) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var fname = 'pdfsrc_' + jobId + '_' + String(pageNum).padStart(4, '0') + '.json';
    var files = folder.getFilesByName(fname);
    if (!files.hasNext()) return null;
    return JSON.parse(files.next().getBlob().getDataAsString());
  } catch (e) {
    Logger.log('loadSourcePdfPage error: ' + e.toString());
    return null;
  }
}

function cleanupSourcePdfPages(jobId) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var files = folder.getFiles();
    var prefix = 'pdfsrc_' + jobId + '_';
    while (files.hasNext()) {
      var f = files.next();
      if (f.getName().indexOf(prefix) === 0) f.setTrashed(true);
    }
  } catch (e) { }
}

function detectRepeatedPdfLines(pages) {
  var counts = {};
  var total = pages.length || 1;

  pages.forEach(function(p) {
    var seen = {};
    String(p.text || '')
      .split(/\n+/)
      .map(function(x) { return x.trim().replace(/\s+/g, ' '); })
      .filter(function(x) { return x.length >= 3 && x.length <= 120; })
      .forEach(function(line) { seen[line] = true; });

    Object.keys(seen).forEach(function(line) {
      counts[line] = (counts[line] || 0) + 1;
    });
  });

  var repeated = [];
  Object.keys(counts).forEach(function(line) {
    if (counts[line] >= Math.max(2, Math.ceil(total * 0.6))) repeated.push(line);
  });
  return repeated;
}

function stripRepeatedPdfLines(text, repeatedLines) {
  var map = {};
  (repeatedLines || []).forEach(function(x) { map[String(x).trim()] = true; });

  return String(text || '')
    .split(/\n+/)
    .map(function(x) { return x.trim().replace(/\s+/g, ' '); })
    .filter(function(line) {
      if (!line) return false;
      return !map[line];
    })
    .join('\n');
}

function generateCleanPdfPageHtml(pageNum, totalPages, cleanedText, documentTitle) {
  var prompt =
    'You are rebuilding an authorized PDF into a clean, well-structured HTML document.\n\n' +
    'SOURCE DOCUMENT TITLE: ' + documentTitle + '\n' +
    'PAGE: ' + pageNum + ' of ' + totalPages + '\n\n' +
    'IMPORTANT RULES:\n' +
    '- Preserve the same meaning and all useful content from the source page.\n' +
    '- Do not add new facts.\n' +
    '- Do not mention watermark removal.\n' +
    '- Do not include repeated watermark/header/footer noise.\n' +
    '- Improve structure using headings, paragraphs, lists, callouts, and tables only when appropriate.\n' +
    '- Return only HTML that can go inside <div class="content">.\n\n' +
    'SOURCE PAGE TEXT:\n' + cleanedText;

  return callOpenAI(
    prompt,
    3500,
    'You convert extracted PDF page text into clean semantic HTML while preserving the original content.'
  );
}

function generatePdfRebuildPageHtml(pageNum, totalPages, contentHtml, title) {
  return '\n  <div class="content-section clearfix pdf-rebuild-page">\n' +
    '    <div class="section-label">Source PDF Page ' + pageNum + ' of ' + totalPages + '</div>\n' +
    '    <h2 class="subheader-title">' + escapeHtml(title || 'Clean PDF Rebuild') + ' — Page ' + pageNum + '</h2>\n' +
    '    <div class="content">\n      ' + contentHtml + '\n    </div>\n' +
    '    <div class="clearfix"></div>\n' +
    '  </div>\n';
}

function initializePdfCleanJob(params) {
  try {
    params = params || {};
    var title = (params.title || 'Clean PDF Rebuild').toString().trim();
    var userName = params.userName || '';
    var userEmail = params.userEmail || '';
    var courseMode = String(params.courseMode || 'custom').toLowerCase() === 'rms' ? 'rms' : 'custom';
    var rmsCourseName = String(params.rmsCourseName || (courseMode === 'rms' ? title : '') || '').trim();
    var rmsCourseId = String(params.rmsCourseId || '').trim();
    var storeToDb = courseMode === 'rms';
    if (courseMode === 'rms' && !rmsCourseName) return { success: false, message: 'Please select an RMS course from the dropdown.', logs: [] };
    if (courseMode === 'rms') title = rmsCourseName;
    var confirmed = params.permissionConfirmed === true;
    var pages = Array.isArray(params.pages) ? params.pages : null; // legacy/small-PDF support
    var pageCount = pages ? pages.length : (parseInt(params.pageCount, 10) || 0);

    if (!confirmed) return { success: false, message: 'Please confirm you have permission to process this PDF.', logs: [] };
    if (!pageCount) return { success: false, message: 'No extractable pages were found in the PDF.', logs: [] };

    var jobId = Utilities.getUuid();
    var logs = [];
    logs.push({ time: new Date().toLocaleTimeString(), message: 'Starting clean PDF rebuild...', type: 'info' });
    logs.push({ time: new Date().toLocaleTimeString(), message: 'Preparing ' + pageCount + ' PDF pages for chunked upload...', type: 'info' });
    logs.push({ time: new Date().toLocaleTimeString(), message: 'Course source: ' + (storeToDb ? 'RMS course — DB upload enabled' : 'Custom course — DB upload skipped'), type: 'info' });

    var ulr = logUserToSpreadsheet(userName, userEmail, title, jobId, JSON.stringify({
      mode: 'pdf_clean_rebuild',
      title: title,
      totalPages: pageCount,
      courseMode: courseMode,
      rmsCourseName: rmsCourseName,
      rmsCourseId: rmsCourseId,
      storeToDb: storeToDb
    }));

    var htmlHeader = generateHTMLHeader(title);
    var job = {
      id: jobId,
      mode: 'pdf_clean_rebuild',
      courseName: title,
      userName: userName,
      userEmail: userEmail,
      courseMode: courseMode,
      rmsCourseName: rmsCourseName,
      rmsCourseId: rmsCourseId,
      storeToDb: storeToDb,
      userLogRow: ulr.success ? ulr.row : null,
      totalPages: pageCount,
      currentTask: 0,
      totalTasks: pageCount,
      uploadedSourcePages: 0,
      status: 'uploading_pdf_pages',
      costs: { textInputTokens: 0, textOutputTokens: 0, imagesGenerated: 0, textCost: 0, imageCost: 0, totalCost: 0 }
    };

    saveJobState(jobId, job, true);
    backupHtmlHeader(jobId, htmlHeader);

    // Backward compatibility for small PDFs sent in one request. Large PDFs should use uploadPdfCleanPageBatch().
    if (pages && pages.length) {
      var repeatedLines = detectRepeatedPdfLines(pages);
      for (var i = 0; i < pages.length; i++) {
        backupSourcePdfPage(jobId, i + 1, {
          pageNumber: i + 1,
          text: pages[i].text || '',
          cleanedText: stripRepeatedPdfLines(pages[i].text || '', repeatedLines)
        });
      }
      job.uploadedSourcePages = pages.length;
      job.status = 'initialized';
      saveJobState(jobId, job, true);
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Uploaded ' + pages.length + ' source pages.', type: 'success' });
    }

    return { success: true, jobId: jobId, totalTasks: pageCount, htmlHeader: htmlHeader, logs: logs };
  } catch (e) {
    return { success: false, message: e.toString(), logs: [] };
  }
}

function uploadPdfCleanPageBatch(jobId, pageBatch) {
  try {
    var job = loadJobState(jobId);
    if (!job) return { success: false, message: 'Job not found', logs: [] };
    if (job.mode !== 'pdf_clean_rebuild') return { success: false, message: 'Not a PDF rebuild job', logs: [] };
    if (!Array.isArray(pageBatch) || !pageBatch.length) return { success: false, message: 'No pages in upload batch', logs: [] };

    var uploaded = parseInt(job.uploadedSourcePages, 10) || 0;
    for (var i = 0; i < pageBatch.length; i++) {
      var p = pageBatch[i] || {};
      var n = parseInt(p.pageNumber, 10) || (uploaded + i + 1);
      backupSourcePdfPage(jobId, n, {
        pageNumber: n,
        text: p.text || '',
        cleanedText: p.cleanedText || p.text || ''
      });
      if (n > uploaded) uploaded = n;
    }

    job.uploadedSourcePages = Math.max(uploaded, parseInt(job.uploadedSourcePages, 10) || 0);
    if (job.uploadedSourcePages >= job.totalPages) job.status = 'initialized';
    saveJobState(jobId, job, true);

    return {
      success: true,
      uploadedSourcePages: job.uploadedSourcePages,
      totalPages: job.totalPages,
      logs: [{ time: new Date().toLocaleTimeString(), message: 'Uploaded source pages ' + pageBatch[0].pageNumber + '-' + pageBatch[pageBatch.length - 1].pageNumber + ' to Drive.', type: 'info' }]
    };
  } catch (e) {
    return { success: false, message: e.toString(), logs: [] };
  }
}

function processNextPdfCleanChunk(jobId) {
  var job = loadJobState(jobId);
  if (!job) return { success: false, done: false, error: 'Job not found', logs: [], htmlChunk: '' };
  if (job.mode !== 'pdf_clean_rebuild') return { success: false, done: false, error: 'Not a PDF rebuild job', logs: [], htmlChunk: '' };

  var logs = [];
  var pageNum = (parseInt(job.currentTask, 10) || 0) + 1;
  var totalPages = parseInt(job.totalTasks, 10) || 1;

  try {
    var sourcePage = loadSourcePdfPage(jobId, pageNum);
    if (!sourcePage) throw new Error('Source page not found: ' + pageNum);

    logs.push({ time: new Date().toLocaleTimeString(), message: 'Rebuilding PDF page ' + pageNum + '/' + totalPages + '...', type: 'info' });
    var cleanedText = sourcePage.cleanedText || sourcePage.text || '';
    if (!cleanedText.trim()) cleanedText = '[This page had no extractable text.]';

    var ai = generateCleanPdfPageHtml(pageNum, totalPages, cleanedText, job.courseName);
    job.costs.textInputTokens += ai.usage.inputTokens || 0;
    job.costs.textOutputTokens += ai.usage.outputTokens || 0;

    var htmlChunk = generatePdfRebuildPageHtml(pageNum, totalPages, ai.content, job.courseName);
    backupChunkHtml(jobId, pageNum - 1, htmlChunk);

    job.currentTask = pageNum;
    var done = job.currentTask >= job.totalTasks;

    if (done) {
      job.status = 'complete';
      job.costs.textCost = (job.costs.textInputTokens / 1e6) * CONFIG.PRICING.TEXT_INPUT_PER_1M + (job.costs.textOutputTokens / 1e6) * CONFIG.PRICING.TEXT_OUTPUT_PER_1M;
      job.costs.totalCost = job.costs.textCost;
      logCostToSpreadsheet(job.costs, job.courseName);
      if (job.userLogRow) updateUserLogStatus(job.userLogRow, 'Completed');
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Clean PDF rebuild complete.', type: 'success' });
    } else {
      logs.push({ time: new Date().toLocaleTimeString(), message: 'Page ' + pageNum + ' generated and saved.', type: 'success' });
    }

    saveJobState(jobId, job, true);
    return { success: true, done: done, currentTask: job.currentTask, totalTasks: job.totalTasks, logs: logs, htmlChunk: htmlChunk };
  } catch (e) {
    logs.push({ time: new Date().toLocaleTimeString(), message: 'Error: ' + e.toString(), type: 'error' });
    if (job.userLogRow) updateUserLogStatus(job.userLogRow, 'Error: ' + e.toString().substring(0, 100));
    saveJobState(jobId, job, true);
    return { success: false, done: false, error: e.toString(), currentTask: job.currentTask, totalTasks: job.totalTasks, logs: logs, htmlChunk: '' };
  }
}

/**
 * Save the HTML header (<!DOCTYPE...><head>...<body>) to Drive so resume can re-initialize the preview.
 */
function backupHtmlHeader(jobId, htmlHeader) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var fname = 'htmlheader_' + jobId + '.txt';
    var existing = folder.getFilesByName(fname);
    if (existing.hasNext()) existing.next().setContent(htmlHeader);
    else folder.createFile(fname, htmlHeader, 'text/plain');
  } catch (e) { Logger.log('backupHtmlHeader error: ' + e.toString()); }
}

function loadHtmlHeader(jobId) {
  try {
    var folder = DriveApp.getFolderById(_getJobsFolderId());
    var fname = 'htmlheader_' + jobId + '.txt';
    var files = folder.getFilesByName(fname);
    if (files.hasNext()) return { success: true, html: files.next().getBlob().getDataAsString() };
    return { success: false };
  } catch (e) { return { success: false }; }
}

/**
 * Called by client on resume — returns everything needed to restore preview and continue generating.
 */
function getJobResumeData(storedJobId) {
  try {
    if (!storedJobId) return { alive: false, message: 'No job ID' };
    var job = loadJobState(storedJobId);
    if (!job) return { alive: false, message: 'Job not found in cache or Drive' };
    if (job.status === 'complete') return { alive: false, message: 'Job already completed' };

    var headerResult = loadHtmlHeader(storedJobId);
    var htmlHeader = headerResult.success ? headerResult.html : generateHTMLHeader(job.courseName);

    var backupInfo = getHtmlBackupInfo(storedJobId);

    return {
      alive: true,
      htmlHeader: htmlHeader,
      currentTask: parseInt(job.currentTask, 10) || 0,
      totalTasks: parseInt(job.totalTasks, 10) || 1,
      courseName: job.courseName || '',
      status: job.status || 'unknown',
      mode: job.mode || 'coursebook',
      backupInfo: backupInfo
    };
  } catch (e) {
    return { alive: false, message: e.toString() };
  }
}

